<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Google Drive - 我的文件</title>
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Roboto', -apple-system, BlinkMacSystemFont, sans-serif;
            background-color: #f8f9fa;
            color: #202124;
            line-height: 1.4;
        }
        
        .header {
            background: white;
            height: 64px;
            border-bottom: 1px solid #e8eaed;
            display: flex;
            align-items: center;
            padding: 0 24px;
            position: sticky;
            top: 0;
            z-index: 100;
        }
        
        .header-left {
            display: flex;
            align-items: center;
            flex: 1;
        }
        
        .logo {
            display: flex;
            align-items: center;
            margin-right: 32px;
        }
        
        .logo-icon {
            width: 40px;
            height: 40px;
            margin-right: 8px;
            background: linear-gradient(45deg, #4285f4, #34a853, #fbbc05, #ea4335);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: bold;
        }
        
        .search-container {
            flex: 1;
            max-width: 720px;
            position: relative;
        }
        
        .search-box {
            width: 100%;
            height: 48px;
            border: 1px solid #e8eaed;
            border-radius: 24px;
            padding: 0 20px 0 48px;
            font-size: 16px;
            background: #f8f9fa;
            transition: all 0.2s;
        }
        
        .search-box:focus {
            outline: none;
            background: white;
            border-color: #4285f4;
            box-shadow: 0 2px 8px rgba(66, 133, 244, 0.2);
        }
        
        .search-icon {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: #5f6368;
        }
        
        .main-container {
            display: flex;
            min-height: calc(100vh - 64px);
        }
        
        .sidebar {
            width: 256px;
            background: white;
            border-right: 1px solid #e8eaed;
            padding: 16px 0;
        }
        
        .sidebar-section {
            margin-bottom: 24px;
        }
        
        .sidebar-item {
            display: flex;
            align-items: center;
            padding: 8px 24px;
            color: #5f6368;
            text-decoration: none;
            transition: background-color 0.2s;
            cursor: pointer;
        }
        
        .sidebar-item:hover {
            background-color: #f8f9fa;
        }
        
        .sidebar-item.active {
            background-color: #e8f0fe;
            color: #1a73e8;
        }
        
        .sidebar-item .material-icons {
            margin-right: 16px;
        }
        
        .storage-info {
            margin: 24px;
            padding: 16px;
            background: #f8f9fa;
            border-radius: 8px;
            font-size: 14px;
        }
        
        .storage-bar {
            width: 100%;
            height: 4px;
            background: #e8eaed;
            border-radius: 2px;
            margin: 8px 0;
            overflow: hidden;
        }
        
        .storage-progress {
            height: 100%;
            background: linear-gradient(90deg, #4285f4, #34a853);
            transition: width 0.3s;
        }
        
        .content {
            flex: 1;
            padding: 24px;
        }
        
        .toolbar {
            display: flex;
            align-items: center;
            margin-bottom: 24px;
            gap: 16px;
        }
        
        .toolbar-left {
            display: flex;
            gap: 12px;
        }
        
        .btn {
            display: flex;
            align-items: center;
            padding: 10px 24px;
            border: 1px solid #dadce0;
            border-radius: 24px;
            background: white;
            color: #3c4043;
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
        }
        
        .btn:hover {
            background: #f8f9fa;
            border-color: #ccc;
        }
        
        .btn.primary {
            background: #1a73e8;
            color: white;
            border-color: #1a73e8;
        }
        
        .btn.primary:hover {
            background: #1557b0;
        }
        
        .btn .material-icons {
            margin-right: 8px;
            font-size: 20px;
        }
        
        .breadcrumb {
            display: flex;
            align-items: center;
            margin-bottom: 16px;
            font-size: 14px;
            color: #5f6368;
        }
        
        .breadcrumb-item {
            cursor: pointer;
            padding: 4px 8px;
            border-radius: 4px;
            transition: background-color 0.2s;
        }
        
        .breadcrumb-item:hover {
            background-color: #f8f9fa;
        }
        
        .breadcrumb-separator {
            margin: 0 4px;
            color: #dadce0;
        }
        
        .upload-area {
            border: 2px dashed #dadce0;
            border-radius: 8px;
            padding: 48px 24px;
            text-align: center;
            margin-bottom: 32px;
            transition: all 0.3s;
            cursor: pointer;
        }
        
        .upload-area.drag-over {
            border-color: #1a73e8;
            background-color: #e8f0fe;
        }
        
        .upload-area .material-icons {
            font-size: 48px;
            color: #5f6368;
            margin-bottom: 16px;
        }
        
        .upload-area h3 {
            color: #3c4043;
            margin-bottom: 8px;
        }
        
        .upload-area p {
            color: #5f6368;
            font-size: 14px;
        }
        
        .file-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
            gap: 16px;
            margin-top: 24px;
        }
        
        .file-item {
            background: white;
            border-radius: 8px;
            padding: 16px;
            border: 1px solid #e8eaed;
            cursor: pointer;
            transition: all 0.2s;
            position: relative;
        }
        
        .file-item:hover {
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
            border-color: #dadce0;
        }
        
        .file-icon {
            font-size: 32px;
            margin-bottom: 8px;
            text-align: center;
        }
        
        .file-icon.folder {
            color: #4285f4;
        }
        
        .file-icon.document {
            color: #4285f4;
        }
        
        .file-icon.image {
            color: #34a853;
        }
        
        .file-icon.video {
            color: #ea4335;
        }
        
        .file-icon.audio {
            color: #fbbc05;
        }
        
        .file-icon.archive {
            color: #9aa0a6;
        }
        
        .file-name {
            font-size: 14px;
            font-weight: 500;
            color: #3c4043;
            margin-bottom: 4px;
            word-break: break-word;
            line-height: 1.3;
        }
        
        .file-info {
            font-size: 12px;
            color: #5f6368;
            display: flex;
            justify-content: space-between;
        }
        
        .context-menu {
            position: fixed;
            background: white;
            border: 1px solid #e8eaed;
            border-radius: 8px;
            padding: 8px 0;
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
            z-index: 1000;
            display: none;
        }
        
        .context-menu-item {
            padding: 8px 16px;
            cursor: pointer;
            font-size: 14px;
            display: flex;
            align-items: center;
            transition: background-color 0.2s;
        }
        
        .context-menu-item:hover {
            background-color: #f8f9fa;
        }
        
        .context-menu-item .material-icons {
            margin-right: 12px;
            font-size: 18px;
        }
        
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.4);
            z-index: 2000;
            align-items: center;
            justify-content: center;
        }
        
        .modal-content {
            background: white;
            border-radius: 8px;
            padding: 24px;
            width: 400px;
            max-width: 90vw;
        }
        
        .modal-title {
            font-size: 20px;
            font-weight: 500;
            margin-bottom: 16px;
            color: #3c4043;
        }
        
        .modal-input {
            width: 100%;
            padding: 12px;
            border: 1px solid #dadce0;
            border-radius: 4px;
            font-size: 16px;
            margin-bottom: 20px;
        }
        
        .modal-input:focus {
            outline: none;
            border-color: #1a73e8;
        }
        
        .modal-buttons {
            display: flex;
            gap: 12px;
            justify-content: flex-end;
        }
        
        .btn-text {
            background: none;
            border: none;
            color: #1a73e8;
            font-weight: 500;
            padding: 8px 16px;
            border-radius: 4px;
            cursor: pointer;
            transition: background-color 0.2s;
        }
        
        .btn-text:hover {
            background: rgba(26, 115, 232, 0.08);
        }
        
        .loading {
            display: none;
            text-align: center;
            padding: 48px;
            color: #5f6368;
        }
        
        .loading .material-icons {
            font-size: 32px;
            animation: spin 1s linear infinite;
        }
        
        @keyframes spin {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }
        
        .empty-state {
            text-align: center;
            padding: 48px 24px;
            color: #5f6368;
            display: none;
        }
        
        .empty-state .material-icons {
            font-size: 64px;
            margin-bottom: 16px;
            color: #dadce0;
        }
        
        @media (max-width: 768px) {
            .main-container {
                flex-direction: column;
            }
            
            .sidebar {
                width: 100%;
                border-right: none;
                border-bottom: 1px solid #e8eaed;
                display: none;
            }
            
            .file-grid {
                grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
                gap: 12px;
            }
            
            .search-container {
                max-width: none;
                margin: 0 16px;
            }
        }
        
        #fileInput {
            display: none;
        }
        
        .back-button {
            display: none;
            margin-right: 16px;
        }
        
        .back-button.show {
            display: flex;
        }
    </style>
</head>
<body>
    <header class="header">
        <div class="header-left">
            <div class="logo">
                <div class="logo-icon">
                    <i class="material-icons">folder</i>
                </div>
                <span style="font-size: 22px; font-weight: 400; color: #5f6368;">文件</span>
            </div>
            <div class="search-container">
                <div style="position: relative;">
                    <i class="material-icons search-icon">search</i>
                    <input type="text" class="search-box" placeholder="搜索文件" id="searchInput">
                </div>
            </div>
        </div>
    </header>

    <div class="main-container">
        <nav class="sidebar">
            <div class="sidebar-section">
                <a href="#" class="sidebar-item active">
                    <i class="material-icons">folder</i>
                    <span>我的文件</span>
                </a>
                <a href="#" class="sidebar-item">
                    <i class="material-icons">people</i>
                    <span>与我共享</span>
                </a>
                <a href="#" class="sidebar-item">
                    <i class="material-icons">schedule</i>
                    <span>最近访问</span>
                </a>
                <a href="#" class="sidebar-item">
                    <i class="material-icons">star</i>
                    <span>已加星标</span>
                </a>
                <a href="#" class="sidebar-item">
                    <i class="material-icons">delete</i>
                    <span>回收站</span>
                </a>
            </div>
            
            <div class="storage-info">
                <div style="display: flex; justify-content: space-between; margin-bottom: 4px;">
                    <span>存储空间</span>
                    <span id="storageUsage">-</span>
                </div>
                <div class="storage-bar">
                    <div class="storage-progress" id="storageProgress" style="width: 0%"></div>
                </div>
                <div style="font-size: 12px; color: #5f6368; margin-top: 4px;">
                    <span id="storageDetails">正在计算...</span>
                </div>
            </div>
        </nav>

        <main class="content">
            <div class="toolbar">
                <div class="toolbar-left">
                    <button class="btn back-button" id="backButton">
                        <i class="material-icons">arrow_back</i>
                        返回
                    </button>
                    <button class="btn primary" onclick="document.getElementById('fileInput').click()">
                        <i class="material-icons">cloud_upload</i>
                        上传文件
                    </button>
                    <button class="btn" onclick="showCreateFolderModal()">
                        <i class="material-icons">create_new_folder</i>
                        新建文件夹
                    </button>
                </div>
            </div>

            <div class="breadcrumb" id="breadcrumb">
                <span class="breadcrumb-item" data-path="">我的文件</span>
            </div>

            <div class="upload-area" id="uploadArea">
                <i class="material-icons">cloud_upload</i>
                <h3>将文件拖拽到此处上传</h3>
                <p>或点击"上传文件"按钮选择文件</p>
            </div>

            <div class="loading" id="loading">
                <i class="material-icons">refresh</i>
                <p>正在加载...</p>
            </div>

            <div class="empty-state" id="emptyState">
                <i class="material-icons">folder_open</i>
                <h3>此文件夹为空</h3>
                <p>上传文件或创建新文件夹开始使用</p>
            </div>

            <div class="file-grid" id="fileGrid">
            </div>
        </main>
    </div>

    <input type="file" id="fileInput" multiple>

    <div class="context-menu" id="contextMenu">
        <div class="context-menu-item" onclick="renameFile()">
            <i class="material-icons">edit</i>
            重命名
        </div>
        <div class="context-menu-item" onclick="deleteFile()">
            <i class="material-icons">delete</i>
            删除
        </div>
    </div>

    <div class="modal" id="renameModal">
        <div class="modal-content">
            <h2 class="modal-title">重命名</h2>
            <input type="text" class="modal-input" id="renameInput" placeholder="请输入新名称">
            <div class="modal-buttons">
                <button class="btn-text" onclick="hideRenameModal()">取消</button>
                <button class="btn-text" onclick="confirmRename()">重命名</button>
            </div>
        </div>
    </div>

    <div class="modal" id="createFolderModal">
        <div class="modal-content">
            <h2 class="modal-title">新建文件夹</h2>
            <input type="text" class="modal-input" id="folderNameInput" placeholder="请输入文件夹名称">
            <div class="modal-buttons">
                <button class="btn-text" onclick="hideCreateFolderModal()">取消</button>
                <button class="btn-text" onclick="confirmCreateFolder()">创建</button>
            </div>
        </div>
    </div>

    <script>
        let currentPath = '';
        let allFiles = [];
        let filteredFiles = [];
        let contextMenuTarget = null;

        document.addEventListener('DOMContentLoaded', function() {
            loadFiles('');
            loadStorageInfo();
            setupEventListeners();
        });

        function setupEventListeners() {
            const fileInput = document.getElementById('fileInput');
            fileInput.addEventListener('change', handleFileSelect);

            const uploadArea = document.getElementById('uploadArea');
            uploadArea.addEventListener('dragover', handleDragOver);
            uploadArea.addEventListener('dragleave', handleDragLeave);
            uploadArea.addEventListener('drop', handleDrop);
            uploadArea.addEventListener('click', () => fileInput.click());

            const searchInput = document.getElementById('searchInput');
            searchInput.addEventListener('input', handleSearch);

            const backButton = document.getElementById('backButton');
            backButton.addEventListener('click', goBack);

            document.addEventListener('click', hideContextMenu);
            document.addEventListener('contextmenu', function(e) {
                e.preventDefault();
            });

            document.addEventListener('keydown', function(e) {
                if (e.key === 'Escape') {
                    hideRenameModal();
                    hideCreateFolderModal();
                }
            });
        }

        async function loadFiles(path = '') {
            showLoading();
            currentPath = path;
            
            try {
                const response = await fetch(`/api/files?path=${encodeURIComponent(path)}`);
                const data = await response.json();
                
                if (data.success) {
                    allFiles = data.items || [];
                    filteredFiles = [...allFiles];
                    displayFiles();
                    updateBreadcrumbs();
                    updateBackButton();
                } else {
                    console.error('Load files error:', data.error);
                }
            } catch (error) {
                console.error('Load files error:', error);
            }
            
            hideLoading();
        }

        function displayFiles() {
            const fileGrid = document.getElementById('fileGrid');
            const emptyState = document.getElementById('emptyState');
            
            if (filteredFiles.length === 0) {
                fileGrid.style.display = 'none';
                emptyState.style.display = 'block';
                return;
            }
            
            fileGrid.style.display = 'grid';
            emptyState.style.display = 'none';
            
            fileGrid.innerHTML = filteredFiles.map(file => {
                const icon = getFileIcon(file);
                const iconClass = getFileIconClass(file);
                
                return `
                    <div class="file-item" 
                         data-name="${file.name}" 
                         data-type="${file.type}"
                         ondblclick="handleFileDoubleClick('${file.name}', '${file.type}')"
                         oncontextmenu="showContextMenu(event, '${file.name}', '${file.type}')">
                        <div class="file-icon ${iconClass}">
                            <i class="material-icons">${icon}</i>
                        </div>
                        <div class="file-name">${file.name}</div>
                        <div class="file-info">
                            <span>${file.modified}</span>
                            <span>${file.size}</span>
                        </div>
                    </div>
                `;
            }).join('');
        }

        function getFileIcon(file) {
            if (file.type === 'folder') return 'folder';
            
            const ext = file.name.split('.').pop().toLowerCase();
            const iconMap = {
                'pdf': 'picture_as_pdf',
                'doc': 'description', 'docx': 'description',
                'txt': 'description', 'rtf': 'description',
                'xls': 'grid_on', 'xlsx': 'grid_on',
                'ppt': 'slideshow', 'pptx': 'slideshow',
                'jpg': 'image', 'jpeg': 'image', 'png': 'image',
                'gif': 'image', 'svg': 'image', 'webp': 'image',
                'mp4': 'movie', 'avi': 'movie', 'mkv': 'movie',
                'mov': 'movie', 'wmv': 'movie', 'flv': 'movie',
                'mp3': 'audiotrack', 'wav': 'audiotrack', 'flac': 'audiotrack',
                'm4a': 'audiotrack', 'ogg': 'audiotrack',
                'zip': 'archive', 'rar': 'archive', '7z': 'archive',
                'tar': 'archive', 'gz': 'archive',
                'js': 'code', 'html': 'code', 'css': 'code',
                'php': 'code', 'py': 'code', 'java': 'code'
            };
            
            return iconMap[ext] || 'insert_drive_file';
        }

        function getFileIconClass(file) {
            if (file.type === 'folder') return 'folder';
            
            const ext = file.name.split('.').pop().toLowerCase();
            if (['jpg', 'jpeg', 'png', 'gif', 'svg', 'webp'].includes(ext)) return 'image';
            if (['mp4', 'avi', 'mkv', 'mov', 'wmv', 'flv'].includes(ext)) return 'video';
            if (['mp3', 'wav', 'flac', 'm4a', 'ogg'].includes(ext)) return 'audio';
            if (['zip', 'rar', '7z', 'tar', 'gz'].includes(ext)) return 'archive';
            return 'document';
        }

        function handleFileDoubleClick(name, type) {
            if (type === 'folder') {
                enterFolder(name);
            } else {
                downloadFile(name);
            }
        }

        function enterFolder(folderName) {
            const newPath = currentPath ? `${currentPath}/${folderName}` : folderName;
            loadFiles(newPath);
        }

        function downloadFile(fileName) {
            const filePath = currentPath ? `${currentPath}/${fileName}` : fileName;
            const url = `/files/data/${filePath}`;
            window.open(url, '_blank');
        }

        function updateBreadcrumbs() {
            const breadcrumb = document.getElementById('breadcrumb');
            const parts = currentPath ? currentPath.split('/') : [];
            
            let html = '<span class="breadcrumb-item" data-path="" onclick="loadFiles(\'\')">我的文件</span>';
            
            let path = '';
            for (const part of parts) {
                path += (path ? '/' : '') + part;
                html += '<span class="breadcrumb-separator">/</span>';
                html += `<span class="breadcrumb-item" data-path="${path}" onclick="loadFiles('${path}')">${part}</span>`;
            }
            
            breadcrumb.innerHTML = html;
        }

        function updateBackButton() {
            const backButton = document.getElementById('backButton');
            if (currentPath) {
                backButton.classList.add('show');
            } else {
                backButton.classList.remove('show');
            }
        }

        function goBack() {
            const parts = currentPath.split('/');
            parts.pop();
            const parentPath = parts.join('/');
            loadFiles(parentPath);
        }

        function handleFileSelect(event) {
            const files = Array.from(event.target.files);
            uploadFiles(files);
            event.target.value = '';
        }

        function handleDragOver(event) {
            event.preventDefault();
            event.currentTarget.classList.add('drag-over');
        }

        function handleDragLeave(event) {
            event.currentTarget.classList.remove('drag-over');
        }

        function handleDrop(event) {
            event.preventDefault();
            event.currentTarget.classList.remove('drag-over');
            
            const files = Array.from(event.dataTransfer.files);
            uploadFiles(files);
        }

        async function uploadFiles(files) {
            if (files.length === 0) return;
            
            showLoading();
            
            const formData = new FormData();
            files.forEach(file => {
                formData.append('files', file);
            });
            
            try {
                const response = await fetch('/api/upload', {
                    method: 'POST',
                    body: formData
                });
                
                const data = await response.json();
                
                if (data.success) {
                    loadFiles(currentPath);
                    loadStorageInfo();
                } else {
                    alert('上传失败: ' + data.error);
                }
            } catch (error) {
                console.error('Upload error:', error);
                alert('上传失败');
            }
            
            hideLoading();
        }

        async function loadStorageInfo() {
            try {
                const response = await fetch('/api/storage');
                const data = await response.json();
                
                if (data.success) {
                    const usagePercent = (data.used / data.total * 100).toFixed(1);
                    
                    document.getElementById('storageUsage').textContent = `${usagePercent}%`;
                    document.getElementById('storageProgress').style.width = `${usagePercent}%`;
                    document.getElementById('storageDetails').textContent = 
                        `${data.used_formatted} / ${data.total_formatted} • ${data.files} 个文件 • ${data.folders} 个文件夹`;
                }
            } catch (error) {
                console.error('Load storage error:', error);
            }
        }

        function handleSearch(event) {
            const query = event.target.value.toLowerCase().trim();
            
            if (query) {
                filteredFiles = allFiles.filter(file => 
                    file.name.toLowerCase().includes(query)
                );
            } else {
                filteredFiles = [...allFiles];
            }
            
            displayFiles();
        }

        function showContextMenu(event, fileName, fileType) {
            event.preventDefault();
            event.stopPropagation();
            
            contextMenuTarget = { name: fileName, type: fileType };
            
            const contextMenu = document.getElementById('contextMenu');
            contextMenu.style.display = 'block';
            contextMenu.style.left = `${event.pageX}px`;
            contextMenu.style.top = `${event.pageY}px`;
        }

        function hideContextMenu() {
            const contextMenu = document.getElementById('contextMenu');
            contextMenu.style.display = 'none';
            contextMenuTarget = null;
        }

        function renameFile() {
            if (!contextMenuTarget) return;
            
            hideContextMenu();
            showRenameModal();
            
            const input = document.getElementById('renameInput');
            input.value = contextMenuTarget.name;
            input.focus();
            input.select();
        }

        function showRenameModal() {
            document.getElementById('renameModal').style.display = 'flex';
        }

        function hideRenameModal() {
            document.getElementById('renameModal').style.display = 'none';
        }

        async function confirmRename() {
            const newName = document.getElementById('renameInput').value.trim();
            if (!newName || !contextMenuTarget) return;
            
            try {
                const response = await fetch('/api/rename', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        oldName: contextMenuTarget.name,
                        newName: newName,
                        path: currentPath
                    })
                });
                
                const data = await response.json();
                
                if (data.success) {
                    hideRenameModal();
                    loadFiles(currentPath);
                } else {
                    alert('重命名失败: ' + data.error);
                }
            } catch (error) {
                console.error('Rename error:', error);
                alert('重命名失败');
            }
        }

        async function deleteFile() {
            if (!contextMenuTarget) return;
            
            hideContextMenu();
            
            if (!confirm(`确定要删除 "${contextMenuTarget.name}" 吗？`)) {
                return;
            }
            
            try {
                const response = await fetch('/api/delete', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        name: contextMenuTarget.name,
                        path: currentPath
                    })
                });
                
                const data = await response.json();
                
                if (data.success) {
                    loadFiles(currentPath);
                    loadStorageInfo();
                } else {
                    alert('删除失败: ' + data.error);
                }
            } catch (error) {
                console.error('Delete error:', error);
                alert('删除失败');
            }
        }

        function showCreateFolderModal() {
            document.getElementById('createFolderModal').style.display = 'flex';
            const input = document.getElementById('folderNameInput');
            input.value = '';
            input.focus();
        }

        function hideCreateFolderModal() {
            document.getElementById('createFolderModal').style.display = 'none';
        }

        async function confirmCreateFolder() {
            const folderName = document.getElementById('folderNameInput').value.trim();
            if (!folderName) return;
            
            try {
                const response = await fetch('/api/folder', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        name: folderName
                    })
                });
                
                const data = await response.json();
                
                if (data.success) {
                    hideCreateFolderModal();
                    loadFiles(currentPath);
                } else {
                    alert('创建文件夹失败: ' + data.error);
                }
            } catch (error) {
                console.error('Create folder error:', error);
                alert('创建文件夹失败');
            }
        }

        function showLoading() {
            document.getElementById('loading').style.display = 'block';
            document.getElementById('fileGrid').style.display = 'none';
            document.getElementById('emptyState').style.display = 'none';
        }

        function hideLoading() {
            document.getElementById('loading').style.display = 'none';
        }
    </script>
</body>
</html>
