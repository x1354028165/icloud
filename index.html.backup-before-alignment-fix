<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Modern Drive - 私有云盘</title>
    <style>
        :root {
            --primary-color: #1a73e8;
            --surface-color: #ffffff;
            --on-surface: #202124;
            --border-color: #dadce0;
            --hover-color: #f8f9fa;
            --selected-color: #e8f0fe;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Google Sans', Roboto, Arial, sans-serif;
            font-size: 14px;
            line-height: 20px;
            color: var(--on-surface);
            background-color: #fafafa;
            overflow-x: hidden;
        }

        /* 🎯 指挥官要求：优雅登录界面 */
        .login-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 1000;
        }

        .login-card {
            background: white;
            border-radius: 12px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
            padding: 48px;
            width: 100%;
            max-width: 400px;
            text-align: center;
        }

        .drive-icon {
            width: 80px;
            height: 80px;
            background: linear-gradient(45deg, #4285f4, #34a853, #fbbc05, #ea4335);
            border-radius: 20px;
            margin: 0 auto 24px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 36px;
            font-weight: bold;
            color: white;
            text-shadow: 0 2px 4px rgba(0,0,0,0.3);
        }

        .login-title {
            font-size: 24px;
            font-weight: 400;
            margin-bottom: 8px;
            color: #202124;
        }

        .login-subtitle {
            font-size: 16px;
            color: #5f6368;
            margin-bottom: 32px;
        }

        .form-group {
            margin-bottom: 24px;
            text-align: left;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: 500;
            color: #3c4043;
        }

        .form-group input {
            width: 100%;
            padding: 12px 16px;
            border: 1px solid #dadce0;
            border-radius: 8px;
            font-size: 16px;
            transition: all 0.2s;
            background: #fff;
        }

        .form-group input:focus {
            outline: none;
            border-color: #1a73e8;
            box-shadow: 0 0 0 3px rgba(26, 115, 232, 0.1);
        }

        .login-button {
            width: 100%;
            background: linear-gradient(45deg, #1a73e8, #4285f4);
            color: white;
            border: none;
            padding: 12px 24px;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
            margin-top: 8px;
        }

        .login-button:hover {
            box-shadow: 0 2px 8px rgba(26, 115, 232, 0.3);
            transform: translateY(-1px);
        }

        .login-button:disabled {
            background: #dadce0;
            cursor: not-allowed;
            transform: none;
            box-shadow: none;
        }

        .error-message {
            color: #d93025;
            font-size: 14px;
            margin-top: 8px;
        }

        .success-message {
            color: #137333;
            font-size: 14px;
            margin-top: 8px;
        }

        /* 🎯 指挥官要求：极简主界面 */
        .main-container {
            display: none;
            min-height: 100vh;
        }

        .header {
            background: var(--surface-color);
            border-bottom: 1px solid var(--border-color);
            padding: 0 24px;
            height: 64px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .header-left {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .drive-logo {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .drive-logo-icon {
            width: 40px;
            height: 40px;
            background: linear-gradient(45deg, #4285f4, #34a853, #fbbc05, #ea4335);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            font-weight: bold;
            color: white;
        }

        .drive-logo-text {
            font-size: 22px;
            font-weight: 400;
            color: #5f6368;
        }

        .header-right {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        /* 🎯 指挥官要求：上传按钮替代Upload Area */
        .upload-btn {
            background: var(--primary-color);
            color: white;
            border: none;
            padding: 8px 24px;
            border-radius: 20px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
        }

        .upload-btn:hover {
            background: #1557b0;
            box-shadow: 0 2px 8px rgba(26, 115, 232, 0.3);
        }

        /* 🚨 新建文件夹按钮样式 */
        .folder-btn {
            background: #34a853;
            color: white;
            border: none;
            padding: 8px 24px;
            border-radius: 20px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
        }

        .folder-btn:hover {
            background: #2d7a3f;
            box-shadow: 0 2px 8px rgba(52, 168, 83, 0.3);
        }

        .user-info {
            font-size: 14px;
            color: #5f6368;
        }

        .logout-btn {
            background: none;
            border: 1px solid var(--border-color);
            padding: 8px 16px;
            border-radius: 20px;
            cursor: pointer;
            color: #5f6368;
            font-size: 14px;
            transition: all 0.2s;
        }

        .logout-btn:hover {
            background: var(--hover-color);
        }

        .main-content {
            display: flex;
            min-height: calc(100vh - 64px);
        }

        .sidebar {
            width: 256px;
            background: var(--surface-color);
            border-right: 1px solid var(--border-color);
            padding: 24px 0;
        }

        .sidebar-item {
            padding: 8px 24px;
            cursor: pointer;
            color: #5f6368;
            font-weight: 500;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .sidebar-item.active {
            background: var(--selected-color);
            color: var(--primary-color);
            border-right: 3px solid var(--primary-color);
        }

        .sidebar-item:hover:not(.active) {
            background: var(--hover-color);
        }

        .content-area {
            flex: 1;
            background: var(--surface-color);
            display: flex;
            flex-direction: column;
        }

        /* 🎯 指挥官要求：面包屑直接顶到文件列表 */
        .content-header {
            padding: 24px;
            border-bottom: 1px solid var(--border-color);
        }

        .breadcrumb {
            font-size: 16px;
            font-weight: 400;
            color: #202124;
        }

        /* 🎯 指挥官要求：文件列表直接顶到面包屑下方 */
        .file-list-container {
            flex: 1;
            overflow: auto;
        }

        .file-list {
            width: 100%;
        }

        .file-header {
            background: #f8f9fa;
            padding: 12px 24px;
            border-bottom: 1px solid var(--border-color);
            font-weight: 500;
            color: #5f6368;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .file-item {
            padding: 12px 24px;
            border-bottom: 1px solid #f1f3f4;
            display: flex;
            align-items: center;
            gap: 16px;
            cursor: pointer;
            transition: all 0.1s;
        }

        .file-item:hover {
            background: var(--hover-color);
        }

        .file-item.selected {
            background: var(--selected-color);
        }

        .file-icon {
            width: 24px;
            height: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
        }

        .file-details {
            flex: 1;
            min-width: 0;
        }

        .file-name {
            font-weight: 400;
            color: #202124;
            margin-bottom: 2px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .file-info {
            font-size: 12px;
            color: #5f6368;
        }

        .file-size {
            font-size: 12px;
            color: #5f6368;
            width: 80px;
            text-align: right;
        }

        .file-modified {
            font-size: 12px;
            color: #5f6368;
            width: 120px;
            text-align: right;
        }

        .loading-container {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 48px;
            color: #5f6368;
        }

        /* 🎯 指挥官要求：全区域拖拽上传 */
        .drag-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(26, 115, 232, 0.1);
            backdrop-filter: blur(4px);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 999;
            font-size: 24px;
            font-weight: 500;
            color: var(--primary-color);
        }

        /* 🛡️ 战术目标二：HTML预览面板 */
        .preview-panel {
            position: fixed;
            top: 0;
            right: -50%;
            width: 50%;
            height: 100%;
            background: white;
            box-shadow: -2px 0 16px rgba(0, 0, 0, 0.1);
            transition: right 0.3s ease;
            z-index: 200;
            display: flex;
            flex-direction: column;
        }

        .preview-panel.open {
            right: 0;
        }

        .preview-header {
            padding: 16px 24px;
            border-bottom: 1px solid var(--border-color);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .preview-title {
            font-weight: 500;
            color: #202124;
        }

        .preview-close {
            background: none;
            border: none;
            font-size: 24px;
            cursor: pointer;
            padding: 4px;
            color: #5f6368;
        }

        .preview-content {
            flex: 1;
            overflow: hidden;
            position: relative;
        }

        /* 🎯 指挥官要求：iframe沙箱渲染 */
        .preview-iframe {
            width: 100%;
            height: 100%;
            border: none;
        }

        .preview-loading {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            color: #5f6368;
        }

        /* 🚨 新建文件夹对话框样式 */
        .dialog-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.5);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 1001;
        }

        .dialog {
            background: white;
            border-radius: 12px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
            padding: 24px;
            width: 100%;
            max-width: 400px;
            text-align: center;
        }

        .dialog-title {
            font-size: 18px;
            font-weight: 500;
            margin-bottom: 16px;
            color: #202124;
        }

        .dialog-input {
            width: 100%;
            padding: 12px 16px;
            border: 1px solid #dadce0;
            border-radius: 8px;
            font-size: 16px;
            margin-bottom: 24px;
        }

        .dialog-input:focus {
            outline: none;
            border-color: #1a73e8;
            box-shadow: 0 0 0 3px rgba(26, 115, 232, 0.1);
        }

        .dialog-buttons {
            display: flex;
            gap: 12px;
            justify-content: flex-end;
        }

        .dialog-btn {
            padding: 8px 16px;
            border: none;
            border-radius: 6px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
        }

        .dialog-btn-primary {
            background: #1a73e8;
            color: white;
        }

        .dialog-btn-primary:hover {
            background: #1557b0;
        }

        .dialog-btn-secondary {
            background: #f8f9fa;
            color: #3c4043;
        }

        .dialog-btn-secondary:hover {
            background: #e8eaed;
        }

        .hidden {
            display: none;
        }

        #fileInput {
            display: none;
        }

        /* 响应式设计 */
        @media (max-width: 768px) {
            .sidebar {
                width: 200px;
            }
            
            .header {
                padding: 0 16px;
            }
            
            .content-header {
                padding: 16px;
            }
            
            .file-item {
                padding: 12px 16px;
            }

            .preview-panel {
                width: 100%;
                right: -100%;
            }
        }
    </style>
</head>
<body>
    <!-- 🎯 指挥官要求：优雅登录界面 -->
    <div id="loginOverlay" class="login-overlay">
        <div class="login-card">
            <div class="drive-icon">MD</div>
            <h1 class="login-title">Modern Drive</h1>
            <p class="login-subtitle">请登录以访问您的私有云盘</p>
            
            <form id="loginForm">
                <div class="form-group">
                    <label for="username">用户名</label>
                    <input type="text" id="username" value="admin" required autocomplete="username">
                </div>
                
                <div class="form-group">
                    <label for="password">密码</label>
                    <input type="password" id="password" value="drive2024" required autocomplete="current-password">
                </div>
                
                <button type="submit" id="loginButton" class="login-button">
                    登录
                </button>
                
                <div id="loginMessage"></div>
            </form>
        </div>
    </div>

    <!-- 🎯 指挥官要求：极简主界面 -->
    <div id="mainContainer" class="main-container">
        <!-- 顶部导航 -->
        <header class="header">
            <div class="header-left">
                <div class="drive-logo">
                    <div class="drive-logo-icon">MD</div>
                    <span class="drive-logo-text">Modern Drive</span>
                </div>
            </div>
            
            <div class="header-right">
                <!-- 🎯 指挥官要求：上传按钮替代Upload Area -->
                <input type="file" id="fileInput" multiple>
                <button class="upload-btn" onclick="document.getElementById('fileInput').click()">
                    📤 上传
                </button>
                <!-- 🚨 紧急修复：新建文件夹按钮 -->
                <button class="folder-btn" onclick="showCreateFolderDialog()">
                    📁 新建文件夹
                </button>
                <span class="user-info">欢迎, <span id="currentUser">admin</span></span>
                <button class="logout-btn" onclick="logout()">退出</button>
            </div>
        </header>

        <!-- 主要内容区域 -->
        <div class="main-content">
            <!-- 侧边栏 -->
            <nav class="sidebar">
                <div class="sidebar-item active" onclick="navigateToFolder('')">
                    📁 我的文件
                </div>
            </nav>

            <!-- 内容区域 -->
            <main class="content-area">
                <!-- 🎯 指挥官要求：面包屑导航 -->
                <div class="content-header">
                    <div class="breadcrumb" id="breadcrumb">我的文件</div>
                </div>

                <!-- 🎯 指挥官要求：文件列表直接顶到面包屑下方，无Upload Area -->
                <div class="file-list-container">
                    <div id="loadingIndicator" class="loading-container">
                        <div>正在加载文件...</div>
                    </div>
                    
                    <table id="fileList" class="file-list hidden">
                        <thead>
                            <tr class="file-header">
                                <th style="text-align: left; padding-left: 64px;">名称</th>
                                <th style="text-align: right; padding-right: 144px;">大小</th>
                                <th style="text-align: right; padding-right: 24px;">修改时间</th>
                            </tr>
                        </thead>
                        <tbody id="fileListBody">
                        </tbody>
                    </table>
                </div>
            </main>
        </div>

        <!-- 🎯 指挥官要求：全区域拖拽上传遮罩 -->
        <div id="dragOverlay" class="drag-overlay">
            <div>📤 释放文件以上传</div>
        </div>

        <!-- 🛡️ 战术目标二：HTML预览面板 -->
        <div id="previewPanel" class="preview-panel">
            <div class="preview-header">
                <div class="preview-title" id="previewTitle">文件预览</div>
                <button class="preview-close" onclick="closePreview()">✕</button>
            </div>
            <div class="preview-content">
                <div class="preview-loading" id="previewLoading">正在加载...</div>
                <!-- 🎯 指挥官要求：iframe沙箱渲染 -->
                <iframe id="previewFrame" class="preview-iframe hidden" 
                        sandbox="allow-scripts allow-same-origin allow-forms"></iframe>
            </div>
        </div>
    </div>

    <!-- 🚨 新建文件夹对话框 -->
    <div id="createFolderDialog" class="dialog-overlay">
        <div class="dialog">
            <h3 class="dialog-title">新建文件夹</h3>
            <input type="text" id="folderNameInput" class="dialog-input" placeholder="输入文件夹名称" maxlength="100">
            <div class="dialog-buttons">
                <button class="dialog-btn dialog-btn-secondary" onclick="hideCreateFolderDialog()">取消</button>
                <button class="dialog-btn dialog-btn-primary" onclick="createFolder()">创建</button>
            </div>
        </div>
    </div>

    <script>
        // 全局变量
        let authToken = localStorage.getItem('auth_token');
        let currentUser = localStorage.getItem('current_user');
        let currentPath = '';

        // 页面加载时检查登录状态
        document.addEventListener('DOMContentLoaded', function() {
            if (authToken && currentUser) {
                showMainInterface();
                loadFiles();
            } else {
                showLoginInterface();
            }
            
            // 🎯 指挥官要求：全区域拖拽上传
            setupDragAndDrop();
            setupFileUpload();
        });

        // 显示登录界面
        function showLoginInterface() {
            document.getElementById('loginOverlay').style.display = 'flex';
            document.getElementById('mainContainer').style.display = 'none';
        }

        // 显示主界面
        function showMainInterface() {
            document.getElementById('loginOverlay').style.display = 'none';
            document.getElementById('mainContainer').style.display = 'block';
            document.getElementById('currentUser').textContent = currentUser || 'admin';
        }

        // 登录处理
        document.getElementById('loginForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            
            const username = document.getElementById('username').value;
            const password = document.getElementById('password').value;
            const loginButton = document.getElementById('loginButton');
            const messageDiv = document.getElementById('loginMessage');
            
            loginButton.disabled = true;
            loginButton.textContent = '登录中...';
            messageDiv.innerHTML = '';
            
            try {
                const response = await fetch('/api/login', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ username, password })
                });
                
                const result = await response.json();
                
                if (result.success) {
                    authToken = result.token;
                    currentUser = result.username;
                    
                    localStorage.setItem('auth_token', authToken);
                    localStorage.setItem('current_user', currentUser);
                    
                    messageDiv.innerHTML = '<div class="success-message">登录成功！</div>';
                    
                    setTimeout(() => {
                        showMainInterface();
                        loadFiles();
                    }, 1000);
                } else {
                    messageDiv.innerHTML = '<div class="error-message">' + (result.error || '登录失败') + '</div>';
                }
            } catch (error) {
                messageDiv.innerHTML = '<div class="error-message">网络错误: ' + error.message + '</div>';
            } finally {
                loginButton.disabled = false;
                loginButton.textContent = '登录';
            }
        });

        // 退出登录
        function logout() {
            if (confirm('确定要退出登录吗？')) {
                localStorage.removeItem('auth_token');
                localStorage.removeItem('current_user');
                authToken = null;
                currentUser = null;
                showLoginInterface();
            }
        }

        // 🚨 新建文件夹功能
        function showCreateFolderDialog() {
            document.getElementById('createFolderDialog').style.display = 'flex';
            document.getElementById('folderNameInput').value = '';
            document.getElementById('folderNameInput').focus();
        }

        function hideCreateFolderDialog() {
            document.getElementById('createFolderDialog').style.display = 'none';
        }

        // 创建文件夹
        async function createFolder() {
            const folderName = document.getElementById('folderNameInput').value.trim();
            
            if (!folderName) {
                alert('请输入文件夹名称');
                return;
            }
            
            if (!authToken) {
                showLoginInterface();
                return;
            }
            
            try {
                const response = await fetch('/api/folder', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': 'Bearer ' + authToken
                    },
                    body: JSON.stringify({
                        name: folderName,
                        path: currentPath
                    })
                });
                
                const result = await response.json();
                
                if (result.success) {
                    hideCreateFolderDialog();
                    await loadFiles(currentPath); // 重新加载文件列表
                    console.log('✅ 文件夹创建成功:', result.folder);
                } else {
                    alert('创建失败: ' + (result.error || '未知错误'));
                }
            } catch (error) {
                alert('创建失败: ' + error.message);
                console.error('创建文件夹错误:', error);
            }
        }

        // 回车键创建文件夹
        document.getElementById('folderNameInput').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                createFolder();
            }
        });

        // ESC键取消对话框
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                hideCreateFolderDialog();
                closePreview();
            }
        });

        // 加载文件列表
        async function loadFiles(path = '') {
            if (!authToken) {
                showLoginInterface();
                return;
            }
            
            currentPath = path;
            
            document.getElementById('loadingIndicator').style.display = 'flex';
            document.getElementById('fileList').classList.add('hidden');
            
            try {
                const url = `/api/files${path ? `?path=${encodeURIComponent(path)}` : ''}`;
                const response = await fetch(url, {
                    headers: {
                        'Authorization': 'Bearer ' + authToken
                    }
                });
                
                if (response.status === 401) {
                    logout();
                    return;
                }
                
                const result = await response.json();
                
                if (result.success) {
                    displayFiles(result.items, path);
                    updateBreadcrumb(path);
                } else {
                    throw new Error(result.error || '加载文件失败');
                }
            } catch (error) {
                document.getElementById('loadingIndicator').innerHTML = 
                    '<div style="color: #d93025;">加载失败: ' + error.message + '</div>';
            }
        }

        // 显示文件列表
        function displayFiles(files, path) {
            document.getElementById('loadingIndicator').style.display = 'none';
            document.getElementById('fileList').classList.remove('hidden');
            
            const tbody = document.getElementById('fileListBody');
            tbody.innerHTML = '';
            
            // 添加返回上级目录选项
            if (path) {
                const backRow = createFileRow({
                    name: '..',
                    type: 'folder',
                    icon: '⬆️'
                }, true);
                tbody.appendChild(backRow);
            }
            
            // 显示文件和文件夹
            files.forEach(file => {
                const row = createFileRow(file, false);
                tbody.appendChild(row);
            });
            
            if (files.length === 0 && !path) {
                tbody.innerHTML = '<tr><td colspan="3" style="text-align: center; padding: 48px; color: #5f6368;">暂无文件</td></tr>';
            }
        }

        // 创建文件行
        function createFileRow(file, isBack) {
            const row = document.createElement('tr');
            row.className = 'file-item';
            
            const icon = file.icon || (file.type === 'folder' ? '📁' : getFileIcon(file.name));
            const size = file.type === 'folder' ? '--' : (file.size || '--');
            const modified = file.modified || '--';
            
            row.innerHTML = `
                <td style="padding-left: 24px;">
                    <div style="display: flex; align-items: center; gap: 16px;">
                        <div class="file-icon">${icon}</div>
                        <div class="file-details">
                            <div class="file-name">${escapeHtml(file.name)}</div>
                        </div>
                    </div>
                </td>
                <td class="file-size">${size}</td>
                <td class="file-modified">${modified}</td>
            `;
            
            row.addEventListener('click', () => {
                if (isBack) {
                    const parentPath = currentPath.split('/').slice(0, -1).join('/');
                    loadFiles(parentPath);
                } else if (file.type === 'folder') {
                    const newPath = currentPath ? `${currentPath}/${file.name}` : file.name;
                    loadFiles(newPath);
                } else {
                    // 🛡️ 战术目标二：HTML文件预览
                    previewFile(file);
                }
            });
            
            return row;
        }

        // 🛡️ 战术目标二核心：HTML预览引擎
        function previewFile(file) {
            const fileName = file.name.toLowerCase();
            const fileExtension = fileName.split('.').pop();
            
            // 🎯 指挥官要求：HTML文件iframe沙箱渲染
            if (fileExtension === 'html' || fileExtension === 'htm') {
                openHtmlPreview(file);
            } else {
                console.log('预览文件:', file.name, '- 类型暂不支持');
                alert('暂不支持此文件类型的预览');
            }
        }

        // 🎯 指挥官要求：HTML文件iframe沙箱渲染
        function openHtmlPreview(file) {
            const panel = document.getElementById('previewPanel');
            const title = document.getElementById('previewTitle');
            const loading = document.getElementById('previewLoading');
            const iframe = document.getElementById('previewFrame');
            
            title.textContent = file.name;
            panel.classList.add('open');
            
            loading.classList.remove('hidden');
            iframe.classList.add('hidden');
            
            const filePath = currentPath ? `${currentPath}/${file.name}` : file.name;
            const fileUrl = `/api/download?path=${encodeURIComponent(filePath)}&inline=true`;
            
            iframe.src = '';
            
            setTimeout(() => {
                iframe.onload = () => {
                    loading.classList.add('hidden');
                    iframe.classList.remove('hidden');
                };
                
                iframe.onerror = () => {
                    loading.textContent = '预览加载失败';
                };
                
                iframe.src = fileUrl;
            }, 100);
        }

        // 关闭预览面板
        function closePreview() {
            const panel = document.getElementById('previewPanel');
            const iframe = document.getElementById('previewFrame');
            
            panel.classList.remove('open');
            iframe.src = '';
        }

        // 获取文件图标
        function getFileIcon(filename) {
            const ext = filename.split('.').pop().toLowerCase();
            
            const iconMap = {
                'html': '🌐',
                'htm': '🌐',
                'css': '🎨',
                'js': '⚡',
                'json': '📋',
                'txt': '📄',
                'md': '📝',
                'pdf': '📕',
                'doc': '📘',
                'docx': '📘',
                'xls': '📗',
                'xlsx': '📗',
                'ppt': '📙',
                'pptx': '📙',
                'zip': '📦',
                'rar': '📦',
                '7z': '📦',
                'jpg': '🖼️',
                'jpeg': '🖼️',
                'png': '🖼️',
                'gif': '🖼️',
                'svg': '🖼️',
                'mp3': '🎵',
                'mp4': '🎬',
                'avi': '🎬'
            };
            
            return iconMap[ext] || '📄';
        }

        // 更新面包屑导航
        function updateBreadcrumb(path) {
            const breadcrumb = document.getElementById('breadcrumb');
            
            if (!path) {
                breadcrumb.innerHTML = '我的文件';
                return;
            }
            
            const parts = path.split('/').filter(p => p);
            let html = '<span onclick="loadFiles(\'\')" style="cursor: pointer;">我的文件</span>';
            
            let currentPath = '';
            parts.forEach(part => {
                currentPath = currentPath ? `${currentPath}/${part}` : part;
                html += ` / <span onclick="loadFiles('${currentPath}')" style="cursor: pointer;">${escapeHtml(part)}</span>`;
            });
            
            breadcrumb.innerHTML = html;
        }

        // 导航到文件夹
        function navigateToFolder(path) {
            loadFiles(path);
        }

        // 🎯 指挥官要求：全区域拖拽上传
        function setupDragAndDrop() {
            const dragOverlay = document.getElementById('dragOverlay');
            let dragCounter = 0;

            ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
                document.addEventListener(eventName, preventDefaults, false);
            });

            function preventDefaults(e) {
                e.preventDefault();
                e.stopPropagation();
            }

            document.addEventListener('dragenter', (e) => {
                if (e.dataTransfer.types.includes('Files')) {
                    dragCounter++;
                    dragOverlay.style.display = 'flex';
                }
            });

            document.addEventListener('dragleave', (e) => {
                dragCounter--;
                if (dragCounter <= 0) {
                    dragCounter = 0;
                    dragOverlay.style.display = 'none';
                }
            });

            document.addEventListener('drop', async (e) => {
                dragCounter = 0;
                dragOverlay.style.display = 'none';
                
                const files = Array.from(e.dataTransfer.files);
                if (files.length > 0) {
                    await uploadFiles(files);
                }
            });
        }

        // 设置文件上传
        function setupFileUpload() {
            document.getElementById('fileInput').addEventListener('change', async function(e) {
                const files = Array.from(e.target.files);
                if (files.length > 0) {
                    await uploadFiles(files);
                }
                e.target.value = '';
            });
        }

        // 🎯 指挥官要求：流式上传配合后端
        async function uploadFiles(files) {
            if (!authToken) {
                showLoginInterface();
                return;
            }

            for (const file of files) {
                try {
                    console.log(`开始上传: ${file.name} (${file.size} bytes)`);
                    
                    const formData = new FormData();
                    formData.append('file', file);
                    
                    const url = `/api/upload${currentPath ? `?path=${encodeURIComponent(currentPath)}` : ''}`;
                    
                    const response = await fetch(url, {
                        method: 'POST',
                        headers: {
                            'Authorization': 'Bearer ' + authToken
                        },
                        body: formData
                    });
                    
                    const result = await response.json();
                    
                    if (result.success) {
                        console.log(`✅ 上传成功: ${file.name}`);
                    } else {
                        console.error(`❌ 上传失败: ${file.name} - ${result.error}`);
                        alert(`上传失败: ${file.name}\n${result.error}`);
                    }
                } catch (error) {
                    console.error(`❌ 上传错误: ${file.name}`, error);
                    alert(`上传错误: ${file.name}\n${error.message}`);
                }
            }
            
            await loadFiles(currentPath);
        }

        // HTML转义
        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }
    </script>
</body>
</html>