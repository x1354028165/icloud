<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Google Drive - 我的文件</title>
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Roboto', -apple-system, BlinkMacSystemFont, sans-serif;
            background-color: #f8f9fa;
            color: #202124;
            line-height: 1.4;
        }
        
        .header {
            background: white;
            height: 64px;
            border-bottom: 1px solid #e8eaed;
            display: flex;
            align-items: center;
            padding: 0 24px;
            position: sticky;
            top: 0;
            z-index: 100;
        }
        
        .header-left {
            display: flex;
            align-items: center;
            flex: 1;
        }
        
        .logo {
            display: flex;
            align-items: center;
            margin-right: 32px;
        }
        
        .logo-icon {
            width: 40px;
            height: 40px;
            margin-right: 8px;
            background: linear-gradient(45deg, #4285f4, #34a853, #fbbc05, #ea4335);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: bold;
        }
        
        .search-container {
            flex: 1;
            max-width: 720px;
            position: relative;
        }
        
        .search-box {
            width: 100%;
            height: 48px;
            border: 1px solid #e8eaed;
            border-radius: 24px;
            padding: 0 20px 0 48px;
            font-size: 16px;
            background: #f8f9fa;
            transition: all 0.2s;
        }
        
        .search-box:focus {
            outline: none;
            background: white;
            border-color: #4285f4;
            box-shadow: 0 2px 8px rgba(66, 133, 244, 0.2);
        }
        
        .search-icon {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: #5f6368;
        }
        
        .main-container {
            display: flex;
            min-height: calc(100vh - 64px);
        }
        
        .sidebar {
            width: 256px;
            background: white;
            border-right: 1px solid #e8eaed;
            padding: 16px 0;
        }
        
        .sidebar-section {
            margin-bottom: 24px;
        }
        
        .sidebar-item {
            display: flex;
            align-items: center;
            padding: 8px 24px;
            color: #5f6368;
            text-decoration: none;
            transition: background-color 0.2s;
            cursor: pointer;
        }
        
        .sidebar-item:hover {
            background-color: #f8f9fa;
        }
        
        .sidebar-item.active {
            background-color: #e8f0fe;
            color: #1a73e8;
        }
        
        .sidebar-item .material-icons {
            margin-right: 16px;
        }
        
        .storage-info {
            margin: 24px;
            padding: 16px;
            background: #f8f9fa;
            border-radius: 8px;
            font-size: 14px;
        }
        
        .storage-bar {
            width: 100%;
            height: 4px;
            background: #e8eaed;
            border-radius: 2px;
            margin: 8px 0;
            overflow: hidden;
        }
        
        .storage-progress {
            height: 100%;
            background: linear-gradient(90deg, #4285f4, #34a853);
            transition: width 0.3s;
        }
        
        .content {
            flex: 1;
            padding: 24px;
        }
        
        .toolbar {
            display: flex;
            align-items: center;
            margin-bottom: 24px;
            gap: 16px;
        }
        
        .toolbar-left {
            display: flex;
            gap: 12px;
        }
        
        .btn {
            display: flex;
            align-items: center;
            padding: 10px 24px;
            border: 1px solid #dadce0;
            border-radius: 24px;
            background: white;
            color: #3c4043;
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
        }
        
        .btn:hover {
            background: #f8f9fa;
            border-color: #ccc;
        }
        
        .btn.primary {
            background: #1a73e8;
            color: white;
            border-color: #1a73e8;
        }
        
        .btn.primary:hover {
            background: #1557b0;
        }
        
        .btn .material-icons {
            margin-right: 8px;
            font-size: 20px;
        }
        
        .breadcrumb {
            display: flex;
            align-items: center;
            margin-bottom: 16px;
            font-size: 14px;
            color: #5f6368;
        }
        
        .breadcrumb-item {
            cursor: pointer;
            padding: 4px 8px;
            border-radius: 4px;
            transition: background-color 0.2s;
        }
        
        .breadcrumb-item:hover {
            background-color: #f8f9fa;
        }
        
        .breadcrumb-separator {
            margin: 0 4px;
            color: #dadce0;
        }
        
        .upload-area {
            border: 2px dashed #dadce0;
            border-radius: 8px;
            padding: 48px 24px;
            text-align: center;
            margin-bottom: 32px;
            transition: all 0.3s;
            cursor: pointer;
        }
        
        .upload-area.drag-over {
            border-color: #1a73e8;
            background-color: #e8f0fe;
        }
        
        .upload-area .material-icons {
            font-size: 48px;
            color: #5f6368;
            margin-bottom: 16px;
        }
        
        .upload-area h3 {
            color: #3c4043;
            margin-bottom: 8px;
        }
        
        .upload-area p {
            color: #5f6368;
            font-size: 14px;
        }
        
        .file-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
            gap: 16px;
            margin-top: 24px;
        }
        
        .file-item {
            background: white;
            border-radius: 8px;
            padding: 16px;
            border: 1px solid #e8eaed;
            cursor: pointer;
            transition: all 0.2s;
            position: relative;
        }
        
        .file-item:hover {
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
            border-color: #dadce0;
        }
        
        .file-icon {
            font-size: 32px;
            margin-bottom: 8px;
            text-align: center;
        }
        
        .file-icon.folder {
            color: #4285f4;
        }
        
        .file-icon.document {
            color: #4285f4;
        }
        
        .file-icon.image {
            color: #34a853;
        }
        
        .file-icon.video {
            color: #ea4335;
        }
        
        .file-icon.audio {
            color: #fbbc05;
        }
        
        .file-icon.archive {
            color: #9aa0a6;
        }
        
        .file-name {
            font-size: 14px;
            font-weight: 500;
            color: #3c4043;
            margin-bottom: 4px;
            word-break: break-word;
            line-height: 1.3;
        }
        
        .file-info {
            font-size: 12px;
            color: #5f6368;
            display: flex;
            justify-content: space-between;
        }
        
        .context-menu {
            position: fixed;
            background: white;
            border: 1px solid #e8eaed;
            border-radius: 8px;
            padding: 8px 0;
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
            z-index: 1000;
            display: none;
        }
        
        .context-menu-item {
            padding: 8px 16px;
            cursor: pointer;
            font-size: 14px;
            display: flex;
            align-items: center;
            transition: background-color 0.2s;
        }
        
        .context-menu-item:hover {
            background-color: #f8f9fa;
        }
        
        .context-menu-item .material-icons {
            margin-right: 12px;
            font-size: 18px;
        }
        
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.4);
            z-index: 2000;
            align-items: center;
            justify-content: center;
        }
        
        .modal-content {
            background: white;
            border-radius: 8px;
            padding: 24px;
            width: 400px;
            max-width: 90vw;
        }
        
        .modal-title {
            font-size: 20px;
            font-weight: 500;
            margin-bottom: 16px;
            color: #3c4043;
        }
        
        .modal-input {
            width: 100%;
            padding: 12px;
            border: 1px solid #dadce0;
            border-radius: 4px;
            font-size: 16px;
            margin-bottom: 20px;
        }
        
        .modal-input:focus {
            outline: none;
            border-color: #1a73e8;
        }
        
        .modal-buttons {
            display: flex;
            gap: 12px;
            justify-content: flex-end;
        }
        
        .btn-text {
            background: none;
            border: none;
            color: #1a73e8;
            font-weight: 500;
            padding: 8px 16px;
            border-radius: 4px;
            cursor: pointer;
            transition: background-color 0.2s;
        }
        
        .btn-text:hover {
            background: rgba(26, 115, 232, 0.08);
        }
        
        .loading {
            display: none;
            text-align: center;
            padding: 48px;
            color: #5f6368;
        }
        
        .loading .material-icons {
            font-size: 32px;
            animation: spin 1s linear infinite;
        }
        
        @keyframes spin {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }
        
        .empty-state {
            text-align: center;
            padding: 48px 24px;
            color: #5f6368;
            display: none;
        }
        
        .empty-state .material-icons {
            font-size: 64px;
            margin-bottom: 16px;
            color: #dadce0;
        }
        
        @media (max-width: 768px) {
            .main-container {
                flex-direction: column;
            }
            
            .sidebar {
                width: 100%;
                border-right: none;
                border-bottom: 1px solid #e8eaed;
                display: none;
            }
            
            .file-grid {
                grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
                gap: 12px;
            }
            
            .search-container {
                max-width: none;
                margin: 0 16px;
            }
        }
        
        
        /* Preview Modal Styles */
        .preview-modal {
            padding: 20px;
        }
        
        .preview-content {
            width: 90vw;
            max-width: 1200px;
            height: 90vh;
            max-height: 800px;
            padding: 0;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }
        
        .preview-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 16px 24px;
            border-bottom: 1px solid #e8eaed;
            background: #f8f9fa;
        }
        
        .preview-close {
            background: none;
            border: none;
            color: #5f6368;
            cursor: pointer;
            padding: 8px;
            border-radius: 50%;
            transition: background-color 0.2s;
        }
        
        .preview-close:hover {
            background-color: rgba(95, 99, 104, 0.1);
        }
        
        .preview-container {
            flex: 1;
            padding: 0;
            overflow: auto;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #f8f9fa;
        }
        
        .preview-content iframe {
            width: 100%;
            height: 100%;
            border: none;
        }
        
        .preview-content img {
            max-width: 100%;
            max-height: 100%;
            object-fit: contain;
        }
        
        .preview-content video {
            max-width: 100%;
            max-height: 100%;
        }
        
        .preview-content pre {
            width: 100%;
            height: 100%;
            margin: 0;
            padding: 20px;
            font-family: "Monaco", "Consolas", monospace;
            font-size: 14px;
            line-height: 1.5;
            background: white;
            overflow: auto;
            white-space: pre-wrap;
            word-wrap: break-word;
        }
        
        .preview-loading {
            display: flex;
            align-items: center;
            justify-content: center;
            flex-direction: column;
            color: #5f6368;
        }
        
        .preview-loading .material-icons {
            font-size: 48px;
            animation: spin 1s linear infinite;
            margin-bottom: 16px;
        }
        
        .preview-error {
            display: flex;
            align-items: center;
            justify-content: center;
            flex-direction: column;
            color: #ea4335;
        }
        
        .preview-error .material-icons {
            font-size: 48px;
            margin-bottom: 16px;
        }
        
        /* Batch Selection Styles */
        .file-item {
            position: relative;
        }
        
        .file-checkbox {
            position: absolute;
            top: 8px;
            left: 8px;
            opacity: 0;
            transition: opacity 0.2s;
            z-index: 10;
        }
        
        .file-item:hover .file-checkbox,
        .file-item.selected .file-checkbox {
            opacity: 1;
        }
        
        .file-checkbox input[type="checkbox"] {
            width: 18px;
            height: 18px;
            accent-color: #1a73e8;
            cursor: pointer;
        }
        
        .file-item.selected {
            background-color: #e8f0fe;
            border-color: #1a73e8;
        }
        
        /* Batch Toolbar */
        .batch-toolbar {
            position: fixed;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
            background: white;
            border: 1px solid #e8eaed;
            border-radius: 24px;
            padding: 12px 24px;
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
            z-index: 1000;
            display: none;
            align-items: center;
            gap: 16px;
        }
        
        .batch-toolbar.show {
            display: flex;
        }
        
        .batch-info {
            font-size: 14px;
            color: #5f6368;
            margin-right: 8px;
        }
        
        .batch-btn {
            display: flex;
            align-items: center;
            padding: 8px 16px;
            border: 1px solid #dadce0;
            border-radius: 16px;
            background: white;
            color: #3c4043;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
            text-decoration: none;
        }
        
        .batch-btn:hover {
            background: #f8f9fa;
        }
        
        .batch-btn.danger {
            background: #ea4335;
            color: white;
            border-color: #ea4335;
        }
        
        .batch-btn.danger:hover {
            background: #d33b2c;
        }
        
        .batch-btn .material-icons {
            margin-right: 6px;
            font-size: 18px;
        }
        
        /* Select All Checkbox */
        .select-all-container {
            display: flex;
            align-items: center;
            margin-left: 16px;
            font-size: 14px;
            color: #5f6368;
            opacity: 0;
            transition: opacity 0.2s;
        }
        
        .select-all-container.show {
            opacity: 1;
        }
        
        .select-all-container input[type="checkbox"] {
            margin-right: 8px;
            accent-color: #1a73e8;
        }
        #fileInput {
            display: none;
        }
        
        .back-button {
            display: none;
            margin-right: 16px;
        }
        
        .back-button.show {
            display: flex;
        }
        
        /* Navigation Enhancement Styles */
        .back-to-parent {
            background-color: #f8f9fa !important;
            border: 1px solid #e8eaed !important;
            margin-bottom: 8px;
            cursor: pointer;
        }
        
        .back-to-parent:hover {
            background-color: #e8f0fe !important;
            border-color: #4285f4 !important;
        }
        
        .back-to-parent .file-icon {
            color: #5f6368;
        }
        
        .back-to-parent .file-name {
            color: #5f6368;
            font-weight: 500;
        }
        
        /* Enhanced file item hover for better click indication */
        .file-item:not(.back-to-parent):hover {
            cursor: pointer;
            transform: translateY(-1px);
            box-shadow: 0 3px 8px rgba(0, 0, 0, 0.12);
        }
        
        /* Checkbox area enhancement for mobile */
        .file-checkbox {
            min-width: 44px;
            min-height: 44px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 4px;
            transition: background-color 0.2s;
        }
        
        .file-checkbox:hover {
            background-color: rgba(66, 133, 244, 0.08);
        }
        
        /* Visual feedback for clickable areas */
        .file-item .file-icon:hover,
        .file-item .file-name:hover {
            color: #1a73e8;
        }
        
        .file-item[data-type="folder"] .file-icon:hover {
            color: #4285f4;
        }
        
        /* Search Enhancement Styles */
        .search-result {
            color: #1a73e8;
            font-weight: 500;
        }
        
        .clear-search-btn {
            background: none;
            border: none;
            color: #5f6368;
            cursor: pointer;
            padding: 4px;
            border-radius: 50%;
            margin-left: 8px;
            transition: all 0.2s;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }
        
        .clear-search-btn:hover {
            background-color: rgba(95, 99, 104, 0.1);
            color: #ea4335;
        }
        
        .clear-search-btn .material-icons {
            font-size: 18px;
        }
        
        /* Search loading animation */
        .search-icon {
            transition: all 0.3s ease;
        }
        
        /* Search result highlighting */
        .file-item[data-search-result="true"] {
            background: linear-gradient(90deg, #e8f0fe 0%, #ffffff 100%);
        }
        
        .file-item[data-search-result="true"]:hover {
            background: linear-gradient(90deg, #e3f2fd 0%, #f8f9fa 100%);
        }
        
        /* Empty search state */
        .empty-state .material-icons[style*="ea4335"] {
            color: #ea4335 !important;
        }
        
        /* Search mode indicator */
        .search-mode-indicator {
            background-color: #e8f0fe;
            border-left: 3px solid #1a73e8;
            padding: 8px 16px;
            margin-bottom: 16px;
            border-radius: 0 4px 4px 0;
            font-size: 14px;
            color: #1a73e8;
        }

        /* ======= 分享系统样式 ======= */
        .share-url-container {
            display: flex;
            gap: 8px;
            align-items: center;
        }

        .share-url-container input {
            flex: 1;
            font-family: monospace;
            font-size: 14px;
            background: #f8f9fa;
        }

        .btn-copy {
            padding: 8px 16px;
            background: #1a73e8;
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-size: 14px;
            white-space: nowrap;
        }

        .btn-copy:hover {
            background: #1557b0;
        }

        .share-result {
            background: #f8f9fa;
            padding: 16px;
            border-radius: 8px;
            border: 1px solid #e8eaed;
            margin-top: 16px;
        }

        .share-info {
            margin-top: 8px;
        }

        .share-info small {
            color: #5f6368;
        }

        .readonly-field {
            padding: 8px 12px;
            background: #f8f9fa;
            border: 1px solid #e8eaed;
            border-radius: 4px;
            color: #3c4043;
            font-weight: 500;
            word-break: break-all;
        }

        .form-group {
            margin-bottom: 16px;
        }

        .form-group label {
            display: block;
            font-weight: 500;
            margin-bottom: 8px;
            color: #3c4043;
        }

        /* 分享菜单项特殊样式 */
        .context-menu-item[data-action="share"] {
            border-top: 1px solid #e8eaed;
            margin-top: 4px;
            padding-top: 8px;
        }

        /* 通知样式 */
        .notification {
            transition: opacity 0.3s ease;
            animation: slideIn 0.3s ease;
        }

        @keyframes slideIn {
            from {
                transform: translateX(100%);
                opacity: 0;
            }
            to {
                transform: translateX(0);
                opacity: 1;
            }
        }

        /* 按钮状态样式 */
        .btn[disabled] {
            opacity: 0.6;
            cursor: not-allowed;
        }

        .btn-primary {
            background: #1a73e8;
            color: white;
            border: 1px solid #1a73e8;
        }

        .btn-primary:hover:not([disabled]) {
            background: #1557b0;
            border-color: #1557b0;
        }

    </style>
</head>
<body>
    <header class="header">
        <div class="header-left">
            <div class="logo">
                <div class="logo-icon">
                    <i class="material-icons">folder</i>
                </div>
                <span style="font-size: 22px; font-weight: 400; color: #5f6368;">文件</span>
            </div>
            <div class="search-container">
                <div style="position: relative;">
                    <i class="material-icons search-icon">search</i>
                    <input type="text" class="search-box" placeholder="搜索文件" id="searchInput">
                </div>
            </div>
        </div>
    </header>

    <div class="main-container">
        <nav class="sidebar">
            <div class="sidebar-section">
                <a href="#" class="sidebar-item active">
                    <i class="material-icons">folder</i>
                    <span>我的文件</span>
                </a>
                <a href="#" class="sidebar-item">
                    <i class="material-icons">people</i>
                    <span>与我共享</span>
                </a>
                <a href="#" class="sidebar-item">
                    <i class="material-icons">schedule</i>
                    <span>最近访问</span>
                </a>
                <a href="#" class="sidebar-item">
                    <i class="material-icons">star</i>
                    <span>已加星标</span>
                </a>
                <a href="#" class="sidebar-item">
                    <i class="material-icons">delete</i>
                    <span>回收站</span>
                </a>
            </div>
            
            <div class="storage-info">
                <div style="display: flex; justify-content: space-between; margin-bottom: 4px;">
                    <span>存储空间</span>
                    <span id="storageUsage">-</span>
                </div>
                <div class="storage-bar">
                    <div class="storage-progress" id="storageProgress" style="width: 0%"></div>
                </div>
                <div style="font-size: 12px; color: #5f6368; margin-top: 4px;">
                    <span id="storageDetails">正在计算...</span>
                </div>
            </div>
        </nav>

        <main class="content">
            <div class="toolbar">
                <div class="toolbar-left">
                    <button class="btn back-button" id="backButton">
                        <i class="material-icons">arrow_back</i>
                        返回
                    </button>
                    <button class="btn primary" onclick="document.getElementById('fileInput').click()">
                        <i class="material-icons">cloud_upload</i>
                        上传文件
                    </button>
                    <button class="btn" onclick="showCreateFolderModal()">
                        <i class="material-icons">create_new_folder</i>
                        新建文件夹
                    </button>
                </div>
            </div>

            <div class="breadcrumb" id="breadcrumb">
            <div class="select-all-container" id="selectAllContainer">
                <input type="checkbox" id="selectAllCheckbox" onchange="toggleSelectAll(this.checked)">
                <span>全选</span>
            </div>
                <span class="breadcrumb-item" data-path="">我的文件</span>
            </div>

            <div class="upload-area" id="uploadArea">
                <i class="material-icons">cloud_upload</i>
                <h3>将文件拖拽到此处上传</h3>
                <p>或点击"上传文件"按钮选择文件</p>
            </div>

            <div class="loading" id="loading">
                <i class="material-icons">refresh</i>
                <p>正在加载...</p>
            </div>

            <div class="empty-state" id="emptyState">
                <i class="material-icons">folder_open</i>
                <h3>此文件夹为空</h3>
                <p>上传文件或创建新文件夹开始使用</p>
            </div>

            <div class="file-grid" id="fileGrid">
            </div>
        </main>
    </div>

    <input type="file" id="fileInput" multiple>

    <div class="context-menu" id="contextMenu">
        <div class="context-menu-item" onclick="previewFileFromContext()">
            <i class="material-icons">visibility</i>
            预览
        </div>
        <div class="context-menu-item" onclick="renameFile()">
            <i class="material-icons">edit</i>
            重命名
        </div>
        <div class="context-menu-item" onclick="deleteFile()">
            <i class="material-icons">delete</i>
            删除
        </div>
    </div>

    <div class="modal" id="renameModal">
        <div class="modal-content">
            <h2 class="modal-title">重命名</h2>
            <input type="text" class="modal-input" id="renameInput" placeholder="请输入新名称">
            <div class="modal-buttons">
                <button class="btn-text" onclick="hideRenameModal()">取消</button>
                <button class="btn-text" onclick="confirmRename()">重命名</button>
            </div>
        </div>
    </div>

    <div class="modal" id="createFolderModal">
        <div class="modal-content">
            <h2 class="modal-title">新建文件夹</h2>
            <input type="text" class="modal-input" id="folderNameInput" placeholder="请输入文件夹名称">
            <div class="modal-buttons">
                <button class="btn-text" onclick="hideCreateFolderModal()">取消</button>
                <button class="btn-text" onclick="confirmCreateFolder()">创建</button>
            </div>
        </div>
    </div>

    <div class="modal" id="shareModal">
        <div class="modal-content">
            <h2 class="modal-title">生成分享链接</h2>
            <div class="form-group">
                <label>文件名:</label>
                <div id="shareFileName" class="readonly-field"></div>
            </div>
            <div class="form-group">
                <label>有效期:</label>
                <select id="shareExpireHours" class="modal-input">
                    <option value="1">1小时 (临时预览)</option>
                    <option value="24" selected>1天 (日常分享)</option>
                    <option value="168">7天 (项目协作)</option>
                    <option value="720">30天 (长期存档)</option>
                </select>
            </div>
            <div class="form-group share-result" style="display:none;">
                <label>分享链接:</label>
                <div class="share-url-container">
                    <input type="text" id="shareUrl" class="modal-input" readonly>
                    <button onclick="copyShareUrl()" class="btn btn-copy">复制</button>
                </div>
                <div class="share-info">
                    <small>过期时间: <span id="shareExpireTime"></span></small>
                </div>
            </div>
            <div class="modal-buttons">
                <button class="btn-text" onclick="hideShareModal()">取消</button>
                <button class="btn btn-primary" onclick="generateShareLink()" id="generateBtn">
                    <i class="material-icons">share</i>
                    生成链接
                </button>
            </div>
        </div>
    </div>

    <script>
        // Preview functionality
        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        function showPreviewModal(fileName, fileType) {
            const modal = document.getElementById('previewModal');
            const title = document.getElementById('previewTitle');
            const container = document.getElementById('previewContainer');
            
            title.textContent = fileName;
            container.innerHTML = '<div class="preview-loading"><i class="material-icons">refresh</i><p>正在加载...</p></div>';
            modal.style.display = 'flex';
            
            const filePath = currentPath ? `${currentPath}/${fileName}` : fileName;
            const fileUrl = `/files/data/${filePath}`;
            
            loadPreviewContent(fileName, fileUrl, container);
        }

        function hidePreviewModal() {
            const modal = document.getElementById('previewModal');
            const container = document.getElementById('previewContainer');
            modal.style.display = 'none';
            container.innerHTML = '';
        }

        function loadPreviewContent(fileName, fileUrl, container) {
            const ext = fileName.split('.').pop().toLowerCase();
            
            // Image preview
            if (['jpg', 'jpeg', 'png', 'gif', 'svg', 'webp', 'bmp'].includes(ext)) {
                container.innerHTML = `<img src="${fileUrl}" alt="${escapeHtml(fileName)}" onerror="showPreviewError(this.parentNode)">`;
                return;
            }
            
            // Video preview
            if (['mp4', 'avi', 'mov', 'mkv', 'webm'].includes(ext)) {
                container.innerHTML = `<video controls autoplay><source src="${fileUrl}" type="video/${ext}">您的浏览器不支持视频播放</video>`;
                return;
            }
            
            // Audio preview
            if (['mp3', 'wav', 'ogg', 'm4a'].includes(ext)) {
                container.innerHTML = `<audio controls autoplay><source src="${fileUrl}" type="audio/${ext}">您的浏览器不支持音频播放</audio>`;
                return;
            }
            
            // PDF preview
            if (ext === 'pdf') {
                container.innerHTML = `<iframe src="${fileUrl}" sandbox="allow-forms allow-scripts allow-same-origin" title="${escapeHtml(fileName)}"></iframe>`;
                return;
            }
            
            // Text file preview
            if (['txt', 'md', 'js', 'py', 'html', 'css', 'json', 'xml', 'log', 'yml', 'yaml', 'sh', 'conf'].includes(ext)) {
                fetch(fileUrl)
                    .then(response => {
                        if (!response.ok) throw new Error('加载失败');
                        return response.text();
                    })
                    .then(text => {
                        if (text.length > 1048576) { // 1MB limit
                            throw new Error('文件过大，无法预览');
                        }
                        container.innerHTML = `<pre>${escapeHtml(text)}</pre>`;
                    })
                    .catch(error => {
                        showPreviewError(container, error.message);
                    });
                return;
            }
            
            // Unsupported file type
            showPreviewError(container, '不支持预览此文件类型');
        }

        function showPreviewError(container, message = '预览失败') {
            container.innerHTML = `<div class="preview-error"><i class="material-icons">error</i><p>${escapeHtml(message)}</p></div>`;
        }

        function previewFileFromContext() {
            if (!contextMenuTarget) return;
            
            hideContextMenu();
            
            // Check if file can be previewed
            const ext = contextMenuTarget.name.split('.').pop().toLowerCase();
            const previewableTypes = [
                'jpg', 'jpeg', 'png', 'gif', 'svg', 'webp', 'bmp',  // images
                'mp4', 'avi', 'mov', 'mkv', 'webm',                 // videos  
                'mp3', 'wav', 'ogg', 'm4a',                         // audio
                'pdf',                                               // documents
                'txt', 'md', 'js', 'py', 'html', 'css', 'json', 'xml', 'log', 'yml', 'yaml', 'sh', 'conf' // text
            ];
            
            if (previewableTypes.includes(ext)) {
                showPreviewModal(contextMenuTarget.name, contextMenuTarget.type);
            } else {
                alert('此文件类型不支持预览');
            }
        }


        let currentPath = '';
        let allFiles = [];
        let filteredFiles = [];
        // Search related variables
        let isSearchMode = false;
        let currentSearchQuery = '';
        let searchTimeout = null;

        // Batch selection variables
        let selectedFiles = [];
        let lastSelectedIndex = -1;

        // Batch selection functions
        function toggleFileSelection(fileName, checked) {
            if (checked) {
                if (!selectedFiles.includes(fileName)) {
                    selectedFiles.push(fileName);
                }
            } else {
                selectedFiles = selectedFiles.filter(f => f !== fileName);
            }
            updateBatchToolbar();
            updateFileItemVisuals();
        }

        function handleFileClick(event, fileName, index, fileType) {
            // 如果点击的是checkbox，已经被stopPropagation处理，不会到达这里
            
            if (event.ctrlKey) {
                // Ctrl+点击: 切换单个文件选择状态
                event.preventDefault();
                const isSelected = selectedFiles.includes(fileName);
                toggleFileSelection(fileName, !isSelected);
                const checkbox = document.getElementById(`checkbox-${index}`);
                if (checkbox) checkbox.checked = !isSelected;
                lastSelectedIndex = index;
            } else if (event.shiftKey && lastSelectedIndex !== -1) {
                // Shift+点击: 区块选择
                event.preventDefault();
                const startIndex = Math.min(lastSelectedIndex, index);
                const endIndex = Math.max(lastSelectedIndex, index);
                
                for (let i = startIndex; i <= endIndex; i++) {
                    const file = filteredFiles[i];
                    if (file && !selectedFiles.includes(file.name)) {
                        selectedFiles.push(file.name);
                        const checkbox = document.getElementById(`checkbox-${i}`);
                        if (checkbox) checkbox.checked = true;
                    }
                }
                updateBatchToolbar();
                updateFileItemVisuals();
            } else {
                // 普通单击: 执行导航/预览逻辑
                const fileData = filteredFiles[index];
                
                if (fileType === 'folder') {
                    if (isSearchMode && fileData && fileData.fullPath) {
                        // 搜索结果中的文件夹，清除搜索并导航到完整路径
                        clearSearch();
                        loadFiles(fileData.fullPath);
                    } else {
                        // 正常浏览模式
                        enterFolder(fileName);
                    }
                } else {
                    // 文件预览逻辑
                    const ext = fileName.split('.').pop().toLowerCase();
                    const previewableTypes = [
                        'jpg', 'jpeg', 'png', 'gif', 'svg', 'webp', 'bmp',  // images
                        'mp4', 'avi', 'mov', 'mkv', 'webm',                 // videos
                        'mp3', 'wav', 'ogg', 'm4a',                         // audio
                        'pdf',                                               // documents
                        'txt', 'md', 'js', 'py', 'html', 'css', 'json', 'xml', 'log', 'yml', 'yaml', 'sh', 'conf' // text
                    ];
                    
                    if (previewableTypes.includes(ext)) {
                        if (isSearchMode && fileData && fileData.fullPath) {
                            // 搜索结果中的文件，使用完整路径预览
                            showPreviewModalWithPath(fileName, fileType, fileData.fullPath);
                        } else {
                            // 正常浏览模式
                            showPreviewModal(fileName, fileType);
                        }
                    } else {
                        if (isSearchMode && fileData && fileData.fullPath) {
                            // 搜索结果中的文件，使用完整路径下载
                            downloadFileWithPath(fileName, fileData.fullPath);
                        } else {
                            // 正常浏览模式
                            downloadFile(fileName);
                        }
                    }
                }
            }
        }
        
        // 辅助函数：使用完整路径预览文件
        function showPreviewModalWithPath(fileName, fileType, fullPath) {
            const modal = document.getElementById('previewModal');
            const title = document.getElementById('previewTitle');
            const container = document.getElementById('previewContainer');
            
            title.textContent = fileName;
            container.innerHTML = '<div class="preview-loading"><i class="material-icons">refresh</i><p>正在加载...</p></div>';
            modal.style.display = 'flex';
            
            const fileUrl = `/files/data/${fullPath}`;
            loadPreviewContent(fileName, fileUrl, container);
        }
        
        // 辅助函数：使用完整路径下载文件
        function downloadFileWithPath(fileName, fullPath) {
            const url = `/files/data/${fullPath}`;
            window.open(url, '_blank');
        }

        function toggleSelectAll(checked) {
            if (checked) {
                selectedFiles = filteredFiles.map(file => file.name);
            } else {
                selectedFiles = [];
            }
            updateBatchToolbar();
            displayFiles(); // 重新渲染以更新所有checkbox状态
        }

        function updateBatchToolbar() {
            const toolbar = document.getElementById('batchToolbar');
            const info = document.getElementById('batchInfo');
            const selectAllContainer = document.getElementById('selectAllContainer');
            const selectAllCheckbox = document.getElementById('selectAllCheckbox');
            
            if (selectedFiles.length > 0) {
                toolbar.classList.add('show');
                info.textContent = `已选择 ${selectedFiles.length} 项`;
                selectAllContainer.classList.add('show');
            } else {
                toolbar.classList.remove('show');
                selectAllContainer.classList.remove('show');
            }
            
            // 更新全选checkbox状态
            if (selectAllCheckbox) {
                if (selectedFiles.length === 0) {
                    selectAllCheckbox.indeterminate = false;
                    selectAllCheckbox.checked = false;
                } else if (selectedFiles.length === filteredFiles.length) {
                    selectAllCheckbox.indeterminate = false;
                    selectAllCheckbox.checked = true;
                } else {
                    selectAllCheckbox.indeterminate = true;
                }
            }
        }

        function updateFileItemVisuals() {
            const fileItems = document.querySelectorAll('.file-item');
            fileItems.forEach((item, index) => {
                const fileName = item.dataset.name;
                const isSelected = selectedFiles.includes(fileName);
                
                if (isSelected) {
                    item.classList.add('selected');
                } else {
                    item.classList.remove('selected');
                }
            });
        }

        function clearSelection() {
            selectedFiles = [];
            updateBatchToolbar();
            displayFiles();
        }

        async function batchDelete() {
            if (selectedFiles.length === 0) return;
            
            if (!confirm(`确定要删除选中的 ${selectedFiles.length} 个文件/文件夹吗？`)) {
                return;
            }
            
            const toolbar = document.getElementById('batchToolbar');
            const originalContent = toolbar.innerHTML;
            toolbar.innerHTML = '<div class="batch-info">正在删除...</div>';
            
            try {
                const response = await fetch('/api/batch-delete', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        files: selectedFiles,
                        path: currentPath
                    })
                });
                
                const data = await response.json();
                
                if (data.success) {
                    // 清空选择
                    selectedFiles = [];
                    
                    // 重新加载文件列表和存储信息
                    await loadFiles(currentPath);
                    await loadStorageInfo();
                    
                    // 显示成功信息
                    toolbar.innerHTML = '<div class="batch-info" style="color: #34a853;">删除成功</div>';
                    setTimeout(() => {
                        updateBatchToolbar();
                    }, 1500);
                } else {
                    throw new Error(data.error || '删除失败');
                }
            } catch (error) {
                console.error('Batch delete error:', error);
                alert('批量删除失败: ' + error.message);
                toolbar.innerHTML = originalContent;
            }
        }

        let contextMenuTarget = null;

        document.addEventListener('DOMContentLoaded', function() {
            loadFiles('');
            loadStorageInfo();
            setupEventListeners();
        });

        function setupEventListeners() {
            const fileInput = document.getElementById('fileInput');
            fileInput.addEventListener('change', handleFileSelect);

            const uploadArea = document.getElementById('uploadArea');
            uploadArea.addEventListener('dragover', handleDragOver);
            uploadArea.addEventListener('dragleave', handleDragLeave);
            uploadArea.addEventListener('drop', handleDrop);
            uploadArea.addEventListener('click', () => fileInput.click());

            const searchInput = document.getElementById('searchInput');
            searchInput.addEventListener('input', handleSearch);

            const backButton = document.getElementById('backButton');
            backButton.addEventListener('click', goBack);

            document.addEventListener('click', hideContextMenu);
            document.addEventListener('contextmenu', function(e) {
                e.preventDefault();
            });

            document.addEventListener('keydown', function(e) {
                if (e.key === 'Escape') {
                    hideRenameModal();
                    hideCreateFolderModal();
                    hideShareModal();
                    hidePreviewModal();
                    if (isSearchMode) {
                        clearSearch();
                        e.preventDefault();
                    } else if (selectedFiles.length > 0) {
                        clearSelection();
                        e.preventDefault();
                    }
                }
                
                // Ctrl+A 全选
                if (e.ctrlKey && e.key === 'a' && !e.target.matches('input, textarea')) {
                    e.preventDefault();
                    const selectAllCheckbox = document.getElementById('selectAllCheckbox');
                    if (selectAllCheckbox) {
                        selectAllCheckbox.checked = true;
                        toggleSelectAll(true);
                    }
                }
                
                // Delete键删除选中文件
                if (e.key === 'Delete' && selectedFiles.length > 0) {
                    e.preventDefault();
                    batchDelete();
                }
            });
        }

        async function loadFiles(path = '') {
            showLoading();
            currentPath = path;
            
            try {
                const response = await fetch(`/api/files?path=${encodeURIComponent(path)}`);
                const data = await response.json();
                
                if (data.success) {
                    allFiles = data.items || [];
                    filteredFiles = [...allFiles];
                    displayFiles();
                    updateBreadcrumbs();
                    updateBackButton();
                } else {
                    console.error('Load files error:', data.error);
                }
            } catch (error) {
                console.error('Load files error:', error);
            }
            
            hideLoading();
        }

        function displayFiles() {
            const fileGrid = document.getElementById('fileGrid');
            const emptyState = document.getElementById('emptyState');
            
            if (filteredFiles.length === 0) {
                fileGrid.style.display = 'none';
                emptyState.style.display = 'block';
                updateBatchToolbar();
                return;
            }
            
            fileGrid.style.display = 'grid';
            emptyState.style.display = 'none';
            
            let html = '';
            
            // 添加返回上一级虚拟行
            if (currentPath) {
                html += `
                    <div class="file-item back-to-parent" onclick="goBack()">
                        <div class="file-icon folder">
                            <i class="material-icons">keyboard_arrow_up</i>
                        </div>
                        <div class="file-name">返回上一级</div>
                        <div class="file-info">
                            <span>-</span>
                            <span>-</span>
                        </div>
                    </div>
                `;
            }
            
            // 渲染文件列表
            html += filteredFiles.map((file, index) => {
                const icon = getFileIcon(file);
                const iconClass = getFileIconClass(file);
                const isSelected = selectedFiles.includes(file.name);
                
                return `
                    <div class="file-item ${isSelected ? 'selected' : ''}" 
                         data-name="${escapeHtml(file.name)}" 
                         data-type="${file.type}"
                         data-index="${index}"
                         onclick="handleFileClick(event, '${file.name}', ${index}, '${file.type}')"
                         oncontextmenu="showContextMenu(event, '${file.name}', '${file.type}')">
                        <div class="file-checkbox">
                            <input type="checkbox" 
                                   id="checkbox-${index}" 
                                   ${isSelected ? 'checked' : ''}
                                   onchange="toggleFileSelection('${file.name}', this.checked)"
                                   onclick="event.stopPropagation()">
                        </div>
                        <div class="file-icon ${iconClass}">
                            <i class="material-icons">${icon}</i>
                        </div>
                        <div class="file-name">${escapeHtml(file.name)}</div>
                        <div class="file-info">
                            <span>${file.modified}</span>
                            <span>${file.size}</span>
                        </div>
                    </div>
                `;
            }).join('');
            
            fileGrid.innerHTML = html;
            updateBatchToolbar();
        }

        function getFileIcon(file) {
            if (file.type === 'folder') return 'folder';
            
            const ext = file.name.split('.').pop().toLowerCase();
            const iconMap = {
                'pdf': 'picture_as_pdf',
                'doc': 'description', 'docx': 'description',
                'txt': 'description', 'rtf': 'description',
                'xls': 'grid_on', 'xlsx': 'grid_on',
                'ppt': 'slideshow', 'pptx': 'slideshow',
                'jpg': 'image', 'jpeg': 'image', 'png': 'image',
                'gif': 'image', 'svg': 'image', 'webp': 'image',
                'mp4': 'movie', 'avi': 'movie', 'mkv': 'movie',
                'mov': 'movie', 'wmv': 'movie', 'flv': 'movie',
                'mp3': 'audiotrack', 'wav': 'audiotrack', 'flac': 'audiotrack',
                'm4a': 'audiotrack', 'ogg': 'audiotrack',
                'zip': 'archive', 'rar': 'archive', '7z': 'archive',
                'tar': 'archive', 'gz': 'archive',
                'js': 'code', 'html': 'code', 'css': 'code',
                'php': 'code', 'py': 'code', 'java': 'code'
            };
            
            return iconMap[ext] || 'insert_drive_file';
        }

        function getFileIconClass(file) {
            if (file.type === 'folder') return 'folder';
            
            const ext = file.name.split('.').pop().toLowerCase();
            if (['jpg', 'jpeg', 'png', 'gif', 'svg', 'webp'].includes(ext)) return 'image';
            if (['mp4', 'avi', 'mkv', 'mov', 'wmv', 'flv'].includes(ext)) return 'video';
            if (['mp3', 'wav', 'flac', 'm4a', 'ogg'].includes(ext)) return 'audio';
            if (['zip', 'rar', '7z', 'tar', 'gz'].includes(ext)) return 'archive';
            return 'document';
        }


        function enterFolder(folderName) {
            const newPath = currentPath ? `${currentPath}/${folderName}` : folderName;
            loadFiles(newPath);
        }

        function downloadFile(fileName) {
            const filePath = currentPath ? `${currentPath}/${fileName}` : fileName;
            const url = `/files/data/${filePath}`;
            window.open(url, '_blank');
        }

        function updateBreadcrumbs() {
            const breadcrumb = document.getElementById('breadcrumb');
            const parts = currentPath ? currentPath.split('/') : [];
            
            let html = '<span class="breadcrumb-item" data-path="" onclick="loadFiles(\'\')">我的文件</span>';
            
            let path = '';
            for (const part of parts) {
                path += (path ? '/' : '') + part;
                html += '<span class="breadcrumb-separator">/</span>';
                html += `<span class="breadcrumb-item" data-path="${path}" onclick="loadFiles('${path}')">${part}</span>`;
            }
            
            breadcrumb.innerHTML = html;
        }

        function updateBackButton() {
            const backButton = document.getElementById('backButton');
            if (currentPath) {
                backButton.classList.add('show');
            } else {
                backButton.classList.remove('show');
            }
        }

        function goBack() {
            const parts = currentPath.split('/');
            parts.pop();
            const parentPath = parts.join('/');
            loadFiles(parentPath);
        }

        function handleFileSelect(event) {
            const files = Array.from(event.target.files);
            uploadFiles(files);
            event.target.value = '';
        }

        function handleDragOver(event) {
            event.preventDefault();
            event.currentTarget.classList.add('drag-over');
        }

        function handleDragLeave(event) {
            event.currentTarget.classList.remove('drag-over');
        }

        function handleDrop(event) {
            event.preventDefault();
            event.currentTarget.classList.remove('drag-over');
            
            const files = Array.from(event.dataTransfer.files);
            uploadFiles(files);
        }

        async function uploadFiles(files) {
            if (files.length === 0) return;
            
            showLoading();
            
            const formData = new FormData();
            files.forEach(file => {
                formData.append('files', file);
            });
            
            try {
                const response = await fetch('/api/upload', {
                    method: 'POST',
                    body: formData
                });
                
                const data = await response.json();
                
                if (data.success) {
                    loadFiles(currentPath);
                    loadStorageInfo();
                } else {
                    alert('上传失败: ' + data.error);
                }
            } catch (error) {
                console.error('Upload error:', error);
                alert('上传失败');
            }
            
            hideLoading();
        }

        async function loadStorageInfo() {
            try {
                const response = await fetch('/api/storage');
                const data = await response.json();
                
                if (data.success) {
                    const usagePercent = (data.used / data.total * 100).toFixed(1);
                    
                    document.getElementById('storageUsage').textContent = `${usagePercent}%`;
                    document.getElementById('storageProgress').style.width = `${usagePercent}%`;
                    document.getElementById('storageDetails').textContent = 
                        `${data.used_formatted} / ${data.total_formatted} • ${data.files} 个文件 • ${data.folders} 个文件夹`;
                }
            } catch (error) {
                console.error('Load storage error:', error);
            }
        }


        // Enhanced search functionality
        function handleSearch(event) {
            const query = event.target.value.trim();
            
            // Clear previous timeout
            if (searchTimeout) {
                clearTimeout(searchTimeout);
            }
            
            if (query.length === 0) {
                clearSearch();
                return;
            }
            
            if (query.length < 2) {
                // Query too short, don't search
                return;
            }
            
            // Set debounce delay
            searchTimeout = setTimeout(() => {
                performSearch(query);
            }, 300);
        }

        async function performSearch(query) {
            if (currentSearchQuery === query && isSearchMode) return; // Avoid duplicate search
            
            currentSearchQuery = query;
            isSearchMode = true;
            
            // Show search status
            updateSearchUI(true);
            
            try {
                const response = await fetch('/api/search', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ query: query, limit: 100 })
                });
                
                const data = await response.json();
                
                if (data.success) {
                    displaySearchResults(data.results, query);
                } else {
                    showSearchError(data.error || '搜索失败');
                }
            } catch (error) {
                console.error('Search error:', error);
                showSearchError('网络错误，搜索失败');
            } finally {
                updateSearchUI(false);
            }
        }

        function displaySearchResults(results, query) {
            // Update breadcrumb for search mode
            updateBreadcrumbForSearch(query);
            
            // Transform search results to match existing file format
            allFiles = results.map(item => ({
                name: item.name,
                type: item.type,
                size: item.size,
                modified: item.modified,
                fullPath: item.fullPath,
                isSearchResult: true
            }));
            
            filteredFiles = [...allFiles];
            displayFiles();
            updateBatchToolbar();
        }

        function updateSearchUI(isLoading) {
            const searchBox = document.getElementById('searchInput');
            const searchIcon = document.querySelector('.search-icon');
            
            if (isLoading) {
                searchIcon.textContent = 'sync';
                searchIcon.style.animation = 'spin 1s linear infinite';
                searchBox.style.opacity = '0.7';
            } else {
                searchIcon.textContent = 'search';
                searchIcon.style.animation = 'none';
                searchBox.style.opacity = '1';
            }
        }

        function updateBreadcrumbForSearch(query) {
            const breadcrumb = document.getElementById('breadcrumb');
            breadcrumb.innerHTML = `
                <span class="breadcrumb-item" onclick="clearSearch()">我的文件</span>
                <span class="breadcrumb-separator">/</span>
                <span class="breadcrumb-item search-result">搜索结果: "${query}"</span>
                <button class="clear-search-btn" onclick="clearSearch()" title="清除搜索">
                    <i class="material-icons">clear</i>
                </button>
            `;
        }

        function clearSearch() {
            isSearchMode = false;
            currentSearchQuery = '';
            const searchInput = document.getElementById('searchInput');
            if (searchInput) {
                searchInput.value = '';
            }
            
            // Clear search timeout
            if (searchTimeout) {
                clearTimeout(searchTimeout);
                searchTimeout = null;
            }
            
            // Update UI
            updateSearchUI(false);
            
            // Return to current directory browsing
            loadFiles(currentPath);
        }

        function showSearchError(message) {
            const fileGrid = document.getElementById('fileGrid');
            const emptyState = document.getElementById('emptyState');
            
            fileGrid.style.display = 'none';
            emptyState.style.display = 'block';
            emptyState.innerHTML = `
                <i class="material-icons" style="color: #ea4335;">search_off</i>
                <h3>搜索失败</h3>
                <p>${message}</p>
                <button class="btn" onclick="clearSearch()" style="margin-top: 16px;">
                    <i class="material-icons">refresh</i>
                    重新开始
                </button>
            `;
        }

        }

        function showContextMenu(event, fileName, fileType) {
            event.preventDefault();
            event.stopPropagation();
            
            contextMenuTarget = { name: fileName, type: fileType };
            
            const contextMenu = document.getElementById('contextMenu');
            contextMenu.style.display = 'block';
            contextMenu.style.left = `${event.pageX}px`;
            contextMenu.style.top = `${event.pageY}px`;
        }

        function hideContextMenu() {
            const contextMenu = document.getElementById('contextMenu');
            contextMenu.style.display = 'none';
            contextMenuTarget = null;
        }

        function renameFile() {
            if (!contextMenuTarget) return;
            
            hideContextMenu();
            showRenameModal();
            
            const input = document.getElementById('renameInput');
            input.value = contextMenuTarget.name;
            input.focus();
            input.select();
        }

        function showRenameModal() {
            document.getElementById('renameModal').style.display = 'flex';
        }

        function hideRenameModal() {
            document.getElementById('renameModal').style.display = 'none';
        }

        async function confirmRename() {
            const newName = document.getElementById('renameInput').value.trim();
            if (!newName || !contextMenuTarget) return;
            
            try {
                const response = await fetch('/api/rename', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        oldName: contextMenuTarget.name,
                        newName: newName,
                        path: currentPath
                    })
                });
                
                const data = await response.json();
                
                if (data.success) {
                    hideRenameModal();
                    loadFiles(currentPath);
                } else {
                    alert('重命名失败: ' + data.error);
                }
            } catch (error) {
                console.error('Rename error:', error);
                alert('重命名失败');
            }
        }

        async function deleteFile() {
            if (!contextMenuTarget) return;
            
            hideContextMenu();
            
            if (!confirm(`确定要删除 "${contextMenuTarget.name}" 吗？`)) {
                return;
            }
            
            try {
                const response = await fetch('/api/delete', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        name: contextMenuTarget.name,
                        path: currentPath
                    })
                });
                
                const data = await response.json();
                
                if (data.success) {
                    loadFiles(currentPath);
                    loadStorageInfo();
                } else {
                    alert('删除失败: ' + data.error);
                }
            } catch (error) {
                console.error('Delete error:', error);
                alert('删除失败');
            }
        }

        function showCreateFolderModal() {
            document.getElementById('createFolderModal').style.display = 'flex';
            const input = document.getElementById('folderNameInput');
            input.value = '';
            input.focus();
        }

        function hideCreateFolderModal() {
            document.getElementById('createFolderModal').style.display = 'none';
        }

        // ======= 分享系统 JavaScript 函数 =======
        let currentShareFile = null;

        function showShareModal() {
            if (!contextMenuTarget) return;
            
            const fileName = contextMenuTarget.name;
            const fileType = contextMenuTarget.type;
            
            // 只允许分享文件，不允许分享文件夹
            if (fileType === 'folder') {
                showNotification('暂不支持文件夹分享', 'warning');
                hideContextMenu();
                return;
            }
            
            currentShareFile = { name: fileName, type: fileType };
            document.getElementById('shareFileName').textContent = fileName;
            document.getElementById('shareModal').style.display = 'flex';
            document.querySelector('.share-result').style.display = 'none';
            
            // 重置按钮状态
            const generateBtn = document.getElementById('generateBtn');
            generateBtn.disabled = false;
            generateBtn.innerHTML = '<i class="material-icons">share</i> 生成链接';
            
            hideContextMenu();
        }

        function hideShareModal() {
            document.getElementById('shareModal').style.display = 'none';
            currentShareFile = null;
        }

        async function generateShareLink() {
            if (!currentShareFile) return;
            
            const expireHours = parseInt(document.getElementById('shareExpireHours').value);
            const generateBtn = document.getElementById('generateBtn');
            
            generateBtn.disabled = true;
            generateBtn.innerHTML = '<i class="material-icons">hourglass_empty</i> 生成中...';
            
            try {
                // 构造文件完整路径
                const filePath = currentPath ? `${currentPath}/${currentShareFile.name}` : currentShareFile.name;
                
                const response = await fetch('/api/share', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        file_path: filePath,
                        expire_hours: expireHours
                    })
                });
                
                const data = await response.json();
                
                if (data.success) {
                    document.getElementById('shareUrl').value = data.share_url;
                    document.getElementById('shareExpireTime').textContent = data.expires;
                    document.querySelector('.share-result').style.display = 'block';
                    
                    generateBtn.innerHTML = '<i class="material-icons">done</i> 生成成功';
                    generateBtn.disabled = false;
                    
                    // 自动复制到剪贴板
                    copyShareUrl();
                    
                } else {
                    showNotification('生成分享链接失败: ' + (data.error || '未知错误'), 'error');
                    generateBtn.innerHTML = '<i class="material-icons">share</i> 生成链接';
                    generateBtn.disabled = false;
                }
                
            } catch (error) {
                console.error('Share error:', error);
                showNotification('网络错误，生成失败', 'error');
                generateBtn.innerHTML = '<i class="material-icons">share</i> 生成链接';
                generateBtn.disabled = false;
            }
        }

        function copyShareUrl() {
            const urlInput = document.getElementById('shareUrl');
            urlInput.select();
            urlInput.setSelectionRange(0, 99999); // For mobile devices
            
            try {
                document.execCommand('copy');
                showNotification('分享链接已复制到剪贴板', 'success');
            } catch (err) {
                console.error('Copy failed:', err);
                showNotification('复制失败，请手动复制', 'warning');
            }
        }

        function showNotification(message, type = 'info') {
            // 简单通知实现
            const notification = document.createElement('div');
            notification.className = `notification notification-${type}`;
            notification.textContent = message;
            
            const colors = {
                success: '#4caf50',
                warning: '#ff9800',
                error: '#f44336',
                info: '#2196f3'
            };
            
            notification.style.cssText = `
                position: fixed;
                top: 20px;
                right: 20px;
                padding: 12px 20px;
                background: ${colors[type] || colors.info};
                color: white;
                border-radius: 4px;
                z-index: 10000;
                box-shadow: 0 2px 8px rgba(0,0,0,0.2);
                font-size: 14px;
                max-width: 300px;
                word-wrap: break-word;
            `;
            
            document.body.appendChild(notification);
            
            setTimeout(() => {
                notification.style.opacity = '0';
                setTimeout(() => notification.remove(), 300);
            }, 3000);
        }


        async function confirmCreateFolder() {
            const folderName = document.getElementById('folderNameInput').value.trim();
            if (!folderName) return;
            
            try {
                const response = await fetch('/api/folder', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        name: folderName
                    })
                });
                
                const data = await response.json();
                
                if (data.success) {
                    hideCreateFolderModal();
                    hideShareModal();
                    loadFiles(currentPath);
                } else {
                    alert('创建文件夹失败: ' + data.error);
                }
            } catch (error) {
                console.error('Create folder error:', error);
                alert('创建文件夹失败');
            }
        }

        function showLoading() {
            document.getElementById('loading').style.display = 'block';
            document.getElementById('fileGrid').style.display = 'none';
            document.getElementById('emptyState').style.display = 'none';
        }

        function hideLoading() {
            document.getElementById('loading').style.display = 'none';
        }
    </script>

    <!-- Preview Modal -->
    <div class="modal preview-modal" id="previewModal">
        <div class="modal-content preview-content">
            <div class="preview-header">
                <h2 class="modal-title" id="previewTitle">文件预览</h2>
                <button class="preview-close" onclick="hidePreviewModal()">
                    <i class="material-icons">close</i>
                </button>
            </div>
            <div class="preview-container" id="previewContainer">
                <!-- Preview content will be loaded here -->
            </div>
        </div>
    </div>

    <!-- Batch Toolbar -->
    <div class="batch-toolbar" id="batchToolbar">
        <div class="batch-info" id="batchInfo">已选择 0 项</div>
        <button class="batch-btn danger" onclick="batchDelete()">
            <i class="material-icons">delete</i>
            删除
        </button>
        <button class="batch-btn" onclick="clearSelection()">
            <i class="material-icons">clear</i>
            取消选择
        </button>
    </div>
</body>
